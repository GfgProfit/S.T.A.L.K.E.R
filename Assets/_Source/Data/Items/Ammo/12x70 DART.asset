  itemName: "12x76 \u0434\u0440\u043E\u0442\u0438\u043A"
  shortName: "\u0414\u0440\u043E\u0442\u0438\u043A"
  description: "\u041F\u0443\u043B\u044F-\u0434\u0440\u043E\u0442\u0438\u043A. \u041E\u043F\u0435\u0440\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0438\u0440\u0443\u0435\u0442
    \u043F\u0443\u043B\u044E, \u0447\u0442\u043E \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0435\u0442
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0431\u043E\u044F. \u041C\u0430\u0441\u0441\u0438\u0432\u043D\u043E\u0435
    \u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435 \u0442\u0435\u043B\u043E \u043F\u0443\u043B\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E \u043F\u0440\u043E\u0431\u0438\u0442\u044C
    \u043B\u044E\u0431\u043E\u0439 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442.
    \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u043E\u0445\u043E\u0442\u043D\u0438\u0447\u044C\u0435\u043C \u0440\u0443\u0436\u044C\u0435,
    \u043E\u0431\u0440\u0435\u0437\u0435, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432
    \u0441\u0430\u043C\u043E\u0437\u0430\u0440\u044F\u0434\u043D\u044B\u0445 \u0434\u0440\u043E\u0431\u043E\u0432\u0438\u043A\u0430\u0445."
