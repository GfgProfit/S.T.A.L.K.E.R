  itemName: "5,7 \xD7 28 \u043C\u043C FMJ"
  shortName: FMJ
  description: "\u0421\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u0430\u0442\u0440\u043E\u043D \u043A\u0430\u043B\u0438\u0431\u0440\u0430
    5,7 x 28 \u043C\u043C \u0441 \u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439. \u041E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u043B\u0451\u0442\u0430, \u043C\u0430\u043B\u043E\u0439 \u043E\u0442\u0434\u0430\u0447\u0435\u0439
    \u0438 \u0445\u043E\u0440\u043E\u0448\u0438\u043C\u0438 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0430\u043C\u0438,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u0443\u0434\u043E\u0431\u043D\u044B\u043C
    \u0434\u043B\u044F \u0442\u043E\u0447\u043D\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B
    \u043E\u0447\u0435\u0440\u0435\u0434\u044F\u043C\u0438. \u041C\u0430\u043B\u043E\u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u0435\u043D
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442\u043E\u0432,
    \u043D\u043E \u0445\u043E\u0440\u043E\u0448\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043D\u0435\u0437\u0430\u0449\u0438\u0449\u0451\u043D\u043D\u044B\u0445
    \u0446\u0435\u043B\u0435\u0439."
