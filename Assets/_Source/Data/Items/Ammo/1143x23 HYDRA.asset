  m_Name: 1143x23 HYDRA
  m_EditorClassIdentifier: 
  _itemId: ba87b39b2541642478660d6a8ef9404d
  _itemName: .45 ACP Hydra-Shok
  _shortName: Hydra
  _description: "\u041D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u0442\u0438\u043F \u043F\u0430\u0442\u0440\u043E\u043D\u0430 \u0434\u043B\u044F
    \u043A\u0430\u043B\u0438\u0431\u0440\u0430 .45 ACP \u2014 \u043F\u043E\u043B\u0443\u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u0430\u044F
    \u043F\u0443\u043B\u044F \u0441 \u044D\u043A\u0441\u043F\u0430\u043D\u0441\u0438\u0432\u043D\u043E\u0439
    \u0432\u044B\u0435\u043C\u043A\u043E\u0439 \u0438 \u0441\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C. \u042D\u0442\u043E\u0439
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0438 \u043F\u043E\u043B\u0443\u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u043E\u0439
    \u044D\u043A\u0441\u043F\u0430\u043D\u0441\u0438\u0432\u043D\u043E\u0439 \u0438
    \u0431\u0440\u043E\u043D\u0435\u0431\u043E\u0439\u043D\u043E\u0439 \u043F\u0443\u043B\u044C
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u044B \u043A\u0430\u043A
    \u0432\u0441\u0435 \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0430,
    \u0442\u0430\u043A \u0438 \u0432\u0441\u0435 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043A\u0438
    \u043E\u0431\u043E\u0438\u0445 \u0442\u0438\u043F\u043E\u0432."
