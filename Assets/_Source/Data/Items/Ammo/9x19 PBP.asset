  itemName: "9 \xD7 19 \u043C\u043C \u0411\u041F"
  shortName: "\u0411\u041F"
  description: "\u041F\u043E\u043B\u0443\u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u0430\u044F
    \u043F\u0443\u043B\u044F \u0441 \u044D\u043A\u0441\u043F\u0430\u043D\u0441\u0438\u0432\u043D\u043E\u0439
    \u0432\u044B\u0435\u043C\u043A\u043E\u0439 \u0438\u043C\u0435\u0435\u0442 \u0432\u044B\u0441\u043E\u043A\u043E\u0435
    \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0449\u0435\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0438 \u043D\u0435 \u0441\u043A\u043B\u043E\u043D\u043D\u0430
    \u043A \u0440\u0438\u043A\u043E\u0448\u0435\u0442\u0430\u043C. \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u043A\u0430\u043A \xAB\u043F\u043E\u043B\u0438\u0446\u0435\u0439\u0441\u043A\u0438\u0439\xBB
    \u0431\u043E\u0435\u043F\u0440\u0438\u043F\u0430\u0441 \u0438 \u0432 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u043C
    \u043E\u0440\u0443\u0436\u0438\u0438 \u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0437\u0430\u0449\u0438\u0442\u044B. \u041C\u0430\u043B\u043E\u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u0435\u043D
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442\u043E\u0432."
