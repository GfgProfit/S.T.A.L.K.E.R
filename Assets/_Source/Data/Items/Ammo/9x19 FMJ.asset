  shortName: FMJ
  description: "\u0421\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u0430\u0442\u0440\u043E\u043D \u043A\u0430\u043B\u0438\u0431\u0440\u0430
    9 x 19 \u043C\u043C \u0441 \u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439. \u041E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0445\u043E\u0440\u043E\u0448\u0438\u043C\u0438 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0430\u043C\u0438
    \u0438 \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u043D\u0435\u0434\u043E\u0440\u043E\u0433
    \u0432 \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u0438,
    \u0447\u0442\u043E \u0438 \u043E\u0431\u0443\u0441\u043B\u043E\u0432\u0438\u043B\u043E
    \u0448\u0438\u0440\u043E\u043A\u043E\u0435 \u0435\u0433\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435.
    \u041C\u0430\u043B\u043E\u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u0435\u043D
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442\u043E\u0432."
