  itemName: "\u0413\u0440\u0430\u043D\u0430\u0442\u0430 \u0412\u041E\u0413-25P"
  shortName: "\u0412\u041E\u0413"
  description: "\u0413\u0440\u0430\u043D\u0430\u0442\u0430 \u0434\u043B\u044F \u043F\u043E\u0434\u0441\u0442\u0432\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0433\u0440\u0430\u043D\u0430\u0442\u043E\u043C\u0451\u0442\u0430 \u0413\u041F-25
    \xAB\u041A\u043E\u0441\u0442\u0451\u0440\xBB, \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434\u0441\u0442\u0432\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u0443 \xAB\u0413\u0440\u043E\u043C\u0430\xBB \u0438 \u0440\u0435\u0432\u043E\u043B\u044C\u0432\u0435\u0440\u043D\u043E\u0433\u043E
    \u0433\u0440\u0430\u043D\u0430\u0442\u043E\u043C\u0451\u0442\u0430 \xAB\u0411\u0443\u043B\u044C\u0434\u043E\u0433-6\xBB.
    \u041F\u0435\u0440\u0435\u0434 \u0432\u0437\u0440\u044B\u0432\u043E\u043C \u0433\u0440\u0430\u043D\u0430\u0442\u0430
    \u043F\u043E\u0434\u043F\u0440\u044B\u0433\u0438\u0432\u0430\u0435\u0442 \u043D\u0430
    \u0432\u044B\u0441\u043E\u0442\u0443 \u043E\u043A\u043E\u043B\u043E \u043C\u0435\u0442\u0440\u0430,
    \u0447\u0442\u043E \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0435\u0442
    \u043F\u043E\u0440\u0430\u0436\u0430\u044E\u0449\u0435\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435"
