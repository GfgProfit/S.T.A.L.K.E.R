  _itemName: "9x39 \u043C\u043C \u0421\u041F-6"
  _shortName: "\u0411\u041F"
  _description: "\u0414\u043E\u0437\u0432\u0443\u043A\u043E\u0432\u043E\u0439 \xAB\u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043D\u044B\u0439\xBB
    \u043F\u0430\u0442\u0440\u043E\u043D \u0421\u041F-6 \u043E\u0441\u043D\u0430\u0449\u0451\u043D
    \u043F\u043E\u043B\u0443\u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439 \u0441 \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C
    \u0438\u0437 \u0437\u0430\u043A\u0430\u043B\u0451\u043D\u043D\u043E\u0439 \u0441\u0442\u0430\u043B\u0438.
    \u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0433\u043B\u0443\u0448\u0438\u0442\u0435\u043B\u044F \u0434\u043B\u044F \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F
    \u0431\u0435\u0441\u0448\u0443\u043C\u043D\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B.
    \u0420\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0451\u043D
    \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0440\u0430\u043D\u0430\u0445
    \u2014 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u0446\u0430\u0445 \u0412\u0430\u0440\u0448\u0430\u0432\u0441\u043A\u043E\u0433\u043E
    \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0430. \u042D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u0435\u043D
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442\u043E\u0432."
