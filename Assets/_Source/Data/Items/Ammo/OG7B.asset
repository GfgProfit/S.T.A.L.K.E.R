  _itemName: "\u0413\u0440\u0430\u043D\u0430\u0442\u0430 \u041E\u0413-7\u0412"
  _shortName: "\u041E\u0413-7\u0412"
  _description: "\u041E\u0441\u043A\u043E\u043B\u043E\u0447\u043D\u043E-\u0444\u0443\u0433\u0430\u0441\u043D\u0430\u044F
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u0435\u0445\u043E\u0442\u043D\u0430\u044F
    \u0433\u0440\u0430\u043D\u0430\u0442\u0430. \u041F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438
    \u043F\u0443\u0441\u043A\u043E\u0432\u043E\u0439 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    \u0420\u041F\u0413-7\u0443 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u043E\u0440\u0430\u0436\u0430\u0442\u044C \u0443\u043A\u0440\u044B\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430 \u043D\u0430 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438,
    \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u044E\u0449\u0435\u043C \u0434\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0431\u0440\u043E\u0441\u043A\u0430 \u0440\u0443\u0447\u043D\u043E\u0439 \u0433\u0440\u0430\u043D\u0430\u0442\u044B."
