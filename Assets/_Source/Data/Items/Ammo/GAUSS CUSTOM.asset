  m_Name: GAUSS CUSTOM
  m_EditorClassIdentifier: 
  _itemName: "\u041A\u0443\u0441\u0442\u0430\u0440\u043D\u0430\u044F \u0431\u0430\u0442\u0430\u0440\u0435\u044F"
  _shortName: "\u0413\u0430\u0443\u0441\u0441"
  _description: "\u042D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B \u043F\u043E\u043D\u0438\u0436\u0435\u043D\u043D\u043E\u0439
    \u0451\u043C\u043A\u043E\u0441\u0442\u0438, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0449\u0438\u0435
    \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438 \u043A\u0430\u043F\u0441\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430
    \xAB\u0412\u0441\u043F\u044B\u0448\u043A\u0430\xBB. \u041F\u043E\u043D\u0438\u0436\u0435\u043D\u043D\u0430\u044F
    \u0451\u043C\u043A\u043E\u0441\u0442\u044C \u043E\u0431\u0443\u0441\u043B\u043E\u0432\u043B\u0435\u043D\u0430
    \u043A\u0443\u0441\u0442\u0430\u0440\u043D\u044B\u043C\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u043C\u0438
    \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044F \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432."
