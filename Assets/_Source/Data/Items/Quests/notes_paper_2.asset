  itemName: "\u0417\u0430\u043F\u0438\u0441\u043A\u0430 \u0421\u0442\u0440\u0435\u043B\u043A\u0443"
  shortName: 
  description: "\u0417\u0430\u043F\u0438\u0441\u043A\u0430 \u043D\u0430 \u043B\u0438\u0441\u0442\u0435
    \u0432 \u043A\u043B\u0435\u0442\u043A\u0443: \xAB\u0421\u0442\u0440\u0435\u043B\u043E\u043A,
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0434\u0435\u0448\u0438\u0444\u0440\u0430\u0442\u043E\u0440
    \u044F \u043D\u0430 \u0432\u0441\u044F\u043A\u0438\u0439 \u043F\u043E\u0436\u0430\u0440\u043D\u044B\u0439
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0432 \u043D\u0430\u0448\u0435\u043C
    \u0442\u0430\u0439\u043D\u0438\u043A\u0435 \u043D\u0430 \u041F\u0440\u0438\u043F\u044F\u0442\u0438.
    \u0421\u0435\u0439\u0447\u0430\u0441 \u0438\u0434\u0451\u043C \u0441 \u041F\u0440\u0438\u0437\u0440\u0430\u043A\u043E\u043C
    \u043D\u0430 \xAB\u0410\u0433\u0440\u043E\u043F\u0440\u043E\u043C\xBB, \u043B\u0438\u0448\u043D\u044E\u044E
    \u0441\u043D\u0430\u0440\u044F\u0433\u0443 \u0431\u0440\u043E\u0441\u0438\u043C
    \u0437\u0434\u0435\u0441\u044C. \u0415\u0441\u043B\u0438 \u0447\u0442\u043E,
    \u0437\u0430\u0431\u0438\u0440\u0430\u0439 \u0432\u0441\u0451. \u041D\u0438 \u043F\u0443\u0445\u0430!
    \u041A\u043B\u044B\u043A.\xBB"
