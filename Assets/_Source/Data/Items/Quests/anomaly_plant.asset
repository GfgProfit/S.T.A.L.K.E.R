  _itemName: "\u0410\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E\u0435 \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435"
  _shortName: 
  _description: "\u0420\u0430\u0441\u0442\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0431\u044B\u043B\u043E \u0447\u0430\u0441\u0442\u044C\u044E \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0451\u043D\u043D\u043E\u0439 \u0440\u043E\u0449\u0438.
    \u0414\u0435\u0440\u0435\u0432\u044C\u044F \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u043E \u043E\u0442\u0440\u0435\u0430\u0433\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043D\u0430 \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u0435, \u043D\u043E
    \u0441\u0430\u043C\u043E \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0435 \u043E\u043F\u0430\u0441\u043D\u044B\u0445
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432 \u043F\u043E\u043A\u0430 \u043D\u0435
    \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B\u043E."
