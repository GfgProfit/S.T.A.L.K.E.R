  m_Name: notes_document_case_2
  m_EditorClassIdentifier: 
  _itemId: 35b6b5dd2b75e2e42be9339edebe3d94
  _itemName: "\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u044F
    \u043F\u043E \xAB\u0438\u0437\u0434\u0435\u043B\u0438\u044E \u2116 62\xBB"
  _shortName: 
  _description: "\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u044F,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043F\u0438\u0441\u0430\u043D
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0422\u0422\u0425 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0439
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438.\r\n\u0412 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
    \u0432\u043B\u043E\u0436\u0435\u043D\u0430 \u0437\u0430\u043F\u0438\u0441\u043A\u0430:
    \xAB\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u044E
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0443\u044E \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u044E
    (X8). \u042F \u0431\u0443\u0434\u0443 \u0437\u0430\u043D\u044F\u0442, \u0434\u043E\u0441\u0442\u0430\u0432\u0438\u0448\u044C
    \u0441\u0430\u043C. \u0412 \u041A\u0411\u041E \xAB\u042E\u0431\u0438\u043B\u0435\u0439\u043D\u044B\u0439\xBB
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u0443\u044E
    \u043A\u0430\u0440\u0442\u0443 \u2014 \u0441\u043F\u0443\u0441\u0442\u0438\u0448\u044C\u0441\u044F
    \u043D\u0430 \u043B\u0438\u0444\u0442\u0435 \u043D\u0430 \u043C\u0438\u043D\u0443\u0441
    \u0432\u0442\u043E\u0440\u043E\u0439 \u044D\u0442\u0430\u0436, \u0434\u0430\u043B\u044C\u0448\u0435
    \u0440\u0430\u0437\u0431\u0435\u0440\u0451\u0448\u044C\u0441\u044F \u0441\u0430\u043C.
    \u041A\u0430\u0440\u0442\u0443 \u0434\u043E\u0441\u0442\u0443\u043F\u0430 \u043F\u0440\u0438\u043B\u0430\u0433\u0430\u044E.\xBB\r\n\u2014
    \u041D. \u041B\u0435\u0431\u0435\u0434\u0435\u0432\r\n\u042D\u0442\u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
    \u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u044B \u043F\u043E\u043F\u0430\u0441\u0442\u044C
    \u0432 \u0447\u0443\u0436\u0438\u0435 \u0440\u0443\u043A\u0438: \u043E\u043D\u0438
    \u044F\u0432\u043D\u043E \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0442
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u043E\u0432 \u0421\u0411\u0423."
