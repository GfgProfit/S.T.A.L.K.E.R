  _itemName: "\u0411\u0443\u043C\u0430\u0433\u0438 \u0441 \u0437\u0430\u043F\u0438\u0441\u044F\u043C\u0438"
  _shortName: 
  _description: "\u0412 \u0431\u0443\u043C\u0430\u0433\u0430\u0445 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0441\u044F
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0440\u0430\u0441\u043F\u043E\u0440\u044F\u0436\u0435\u043D\u0438\u044E \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A\u0430
    \u041F\u0435\u0440\u0432\u043E\u0433\u043E \u043E\u0442\u0434\u0435\u043B\u0430
    \u043F\u0443\u0442\u0435\u043F\u0440\u043E\u0432\u043E\u0434 \xAB\u041F\u0440\u0438\u043F\u044F\u0442\u044C-1\xBB
    \u043F\u043E\u0441\u043B\u0435 \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u044B\u0432\u0430\u043D\u0438\u044F
    \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u043D\u043E\u0433\u043E
    \u0448\u043B\u044E\u0437\u0430 \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u043B\u0438
    \u0443\u0433\u043B\u0435\u043A\u0438\u0441\u043B\u044B\u043C \u0433\u0430\u0437\u043E\u043C
    \u0441 \u043D\u0435\u043A\u043E\u0439 \u043F\u0440\u0438\u043C\u0435\u0441\u044C\u044E.
    \u041F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0443 \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u043F\u0440\u0435\u0434\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u043E\u0441\u044C
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u043A\u043E\u0441\u0442\u044E\u043C\u044B
    \u0445\u0438\u043C\u0437\u0430\u0449\u0438\u0442\u044B \u0441 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u0434\u044B\u0445\u0430\u043D\u0438\u044F."
