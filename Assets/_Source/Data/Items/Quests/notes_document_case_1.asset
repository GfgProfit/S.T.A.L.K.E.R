  itemName: "\u041F\u0430\u043F\u043A\u0430 \u0441 \u043F\u0440\u0438\u043A\u0430\u0437\u043E\u043C"
  shortName: 
  description: "\u0412 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0445
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0441\u044F \u043F\u0440\u043E \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u044E
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u0430 \u0441 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438
    \u0437\u0430\u0432\u043E\u0434\u0430 \xAB\u042E\u043F\u0438\u0442\u0435\u0440\xBB
    \u0432 \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u044B\u0435 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438.
    \u041E\u0431\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435 \u044D\u0442\u043E\u0433\u043E
    \u0432\u043E\u043F\u0440\u043E\u0441\u0430 \u0434\u043E\u043B\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u044C\u0441\u044F
    \u0432 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u043D\u043E\u043C
    \u043A\u043E\u0440\u043F\u0443\u0441\u0435."
