  m_Name: notes_letter_2
  m_EditorClassIdentifier: 
  itemName: "\u041F\u0438\u0441\u044C\u043C\u043E \u043E \u043F\u043E\u0441\u0442\u0430\u0432\u043A\u0430\u0445
    \xAB\u0438\u0437\u0434\u0435\u043B\u0438\u044F \u2116 62\xBB"
  shortName: 
  description: "\u0412 \u0441\u0432\u044F\u0437\u0438 \u0441 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F\u043C\u0438 \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u043A\u0430
    \u0438\u0437\u0434\u0435\u043B\u0438\u044F \u2116 62 \u043F\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439
    \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u0430.
    \u0412 \u0434\u0430\u043D\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
    \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F \u0437\u0430\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u044B\u0439 \u043F\u0443\u0442\u0435\u043F\u0440\u043E\u0432\u043E\u0434
    \u041F\u0440\u0438\u043F\u044F\u0442\u044C-1. \u0421\u0445\u0435\u043C\u0430
    \u0434\u043E\u0441\u0442\u0430\u0432\u043A\u0438 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439
    \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0446\u0438\u0438 \u043F\u0443\u0442\u0435\u043F\u0440\u043E\u0432\u043E\u0434\u0430
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430 \u0432 \u041F\u0435\u0440\u0432\u044B\u0439
    \u043E\u0442\u0434\u0435\u043B."
