  _itemId: 11e39530896410a46bc79fefe518abad
  _itemName: "\u0422\u0435\u0442\u0440\u0430\u0434\u044C \u0441 \u0437\u0430\u043F\u0438\u0441\u044C\u044E
    \u043E\u0431 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0435"
  _shortName: 
  _description: "\u0412 \u0442\u0435\u0442\u0440\u0430\u0434\u0438 \u0435\u0441\u0442\u044C
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0435 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430 \u043F\u043E
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u043C\u0443
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044E \u043F\u0441\u0438-\u043F\u043E\u043B\u0435\u043C
    \u043D\u0430 \u043E\u0431\u044A\u0435\u043A\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u0432 \u0434\u0440\u0443\u0433\u043E\u043C
    \u043F\u043E\u043B\u0443\u0448\u0430\u0440\u0438\u0438 \u0417\u0435\u043C\u043B\u0438.
    \u0413\u0440\u0443\u043F\u043F\u0430 \u0443\u0447\u0451\u043D\u044B\u0445 \u043D\u0430
    \u0441\u0443\u0434\u043D\u0435 \u0432 \u041A\u0430\u0440\u0438\u0431\u0441\u043A\u043E\u043C
    \u043C\u043E\u0440\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u0441\u0438\u0433\u043D\u0430\u043B,
    \u043D\u043E \u0441 \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u0438\u044F\u043C\u0438.
    \u041C\u043E\u0434\u0443\u043B\u044F\u0446\u0438\u0438 \u0431\u044B\u043B\u0438
    \u043D\u0435\u043F\u043E\u043D\u044F\u0442\u043D\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C
    \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u044B, \u0441\u043B\u043E\u0432\u043D\u043E
    \xAB\u043F\u043E\u0434\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u044B\xBB \u043A\u0435\u043C-\u0442\u043E.
    \u041E\u0434\u043D\u0430 \u0438\u0437 \u0440\u0430\u0431\u043E\u0447\u0438\u0445
    \u0432\u0435\u0440\u0441\u0438\u0439 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0430
    \u043D\u0430 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043E \u0432\u0435\u0440\u043D\u043E\u0441\u0442\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043D\u043E\u043E\u0441\u0444\u0435\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u044F\u043A\u043E\u0431\u044B \u0438 \u043F\u0440\u0438\u0432\u043D\u0435\u0441\u043B\u0430
    \u044D\u0442\u0438 \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u0438\u044F.\r\n\u042D\u0442\u0438
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u044B
    \u043F\u043E\u043F\u0430\u0441\u0442\u044C \u0432 \u0447\u0443\u0436\u0438\u0435
    \u0440\u0443\u043A\u0438: \u043E\u043D\u0438 \u044F\u0432\u043D\u043E \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0442
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u043E\u0432 \u0421\u0411\u0423."
