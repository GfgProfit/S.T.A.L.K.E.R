  m_Name: AK-74
  m_EditorClassIdentifier: 
  _itemName: "\u0410\u0432\u0442\u043E\u043C\u0430\u0442 \u041A\u0430\u043B\u0430\u0448\u043D\u0438\u043A\u043E\u0432\u0430
    \u0410\u041A-74 5.45x39"
  _shortName: "\u0410\u041A-74"
  _description: "\u0410\u0432\u0442\u043E\u043C\u0430\u0442 \u041A\u0430\u043B\u0430\u0448\u043D\u0438\u043A\u043E\u0432\u0430
    \u043E\u0431\u0440\u0430\u0437\u0446\u0430 1974 \u0433\u043E\u0434\u0430 \u2014
    \u043D\u0430\u0434\u0451\u0436\u043D\u043E\u0435 \u0438 \u043D\u0435\u043F\u0440\u0438\u0445\u043E\u0442\u043B\u0438\u0432\u043E\u0435
    \u043E\u0440\u0443\u0436\u0438\u0435 \u043F\u043E\u0434 \u043F\u0430\u0442\u0440\u043E\u043D
    5.45\xD739 \u043C\u043C. \u0412 \u0417\u043E\u043D\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F
    \u0447\u0430\u0441\u0442\u043E: \u0435\u0433\u043E \u0442\u0430\u0441\u043A\u0430\u044E\u0442
    \u043D\u043E\u0432\u0438\u0447\u043A\u0438, \u0432\u043E\u0435\u043D\u043D\u044B\u0435,
    \u0431\u0430\u043D\u0434\u0438\u0442\u044B \u0438 \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0432\u0430\u0436\u043D\u0435\u0435
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C, \u0447\u0435\u043C
    \u043A\u0440\u0430\u0441\u043E\u0442\u0430. \u0425\u043E\u0440\u043E\u0448\u043E
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0441\u0435\u0431\u044F
    \u043D\u0430 \u0441\u0440\u0435\u0434\u043D\u0435\u0439 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0438,
    \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442 \u0443\u043C\u0435\u0440\u0435\u043D\u043D\u043E\u0439
    \u043E\u0442\u0434\u0430\u0447\u0435\u0439 \u0438 \u043F\u0440\u0438\u0435\u043C\u043B\u0435\u043C\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E. \u041F\u0440\u043E\u0442\u0438\u0432
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\u0439 \u0431\u0440\u043E\u043D\u0438
    \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0431\u043E\u0435\u043F\u0440\u0438\u043F\u0430\u0441\u043E\u0432, \u043D\u043E
    \u0432 \u0443\u043C\u0435\u043B\u044B\u0445 \u0440\u0443\u043A\u0430\u0445 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043E\u0432."
