  itemName: "\u0410\u0440\u043C\u0435\u0439\u0441\u043A\u0430\u044F \u0430\u043F\u0442\u0435\u0447\u043A\u0430"
  shortName: 
  description: "\u0421\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0439 \u043D\u0430\u0431\u043E\u0440
    \u0434\u043B\u044F \u043E\u043A\u0430\u0437\u0430\u043D\u0438\u044F \u043F\u0435\u0440\u0432\u043E\u0439
    \u043F\u043E\u043C\u043E\u0449\u0438 \u043F\u0440\u0438 \u0440\u0430\u043D\u0435\u043D\u0438\u044F\u0445
    \u043D\u0430 \u043F\u043E\u043B\u0435 \u0431\u043E\u044F. \u0412 \u043D\u0430\u0431\u043E\u0440
    \u0432\u0445\u043E\u0434\u044F\u0442 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430
    \u0434\u043B\u044F \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u044F \u0441\u0432\u0435\u0440\u0442\u044B\u0432\u0430\u043D\u0438\u044F
    \u043A\u0440\u043E\u0432\u0438 \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \xAB\u041C\u0435\u043D\u0430\u0434\u0438\u043E\u043D\u0430\xBB, \u043E\u0431\u0435\u0437\u0431\u043E\u043B\u0438\u0432\u0430\u044E\u0449\u0438\u0435,
    \u0430\u043D\u0442\u0438\u0431\u0438\u043E\u0442\u0438\u043A\u0438 \u0438 \u0441\u0442\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440\u044B
    \u0438\u043C\u043C\u0443\u043D\u0438\u0442\u0435\u0442\u0430; \u043A\u0440\u043E\u043C\u0435
    \u0442\u043E\u0433\u043E, \u0437\u0434\u0435\u0441\u044C \u0438\u043C\u0435\u0435\u0442\u0441\u044F
    \u043F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0439 \u0445\u0438\u0440\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043D\u0430\u0431\u043E\u0440 \u0434\u043B\u044F \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u043E\u0441\u043A\u043E\u043B\u043A\u043E\u0432 \u0438 \u043F\u0443\u043B\u044C.
    \u0421\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0430\u044F \u0430\u0440\u043C\u0435\u0439\u0441\u043A\u0430\u044F
    \u0430\u043F\u0442\u0435\u0447\u043A\u0430; \u0440\u0435\u0436\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u044D\u043A\u0438\u043F\u0438\u0440\u043E\u0432\u043A\u0435 \xAB\u0434\u043E\u043B\u0433\u043E\u0432\u0446\u0435\u0432\xBB."
