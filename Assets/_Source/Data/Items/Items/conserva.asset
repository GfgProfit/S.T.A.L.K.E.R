  m_Name: conserva
  m_EditorClassIdentifier: 
  _itemName: "\u041A\u043E\u043D\u0441\u0435\u0440\u0432\u044B \xAB\u0417\u0430\u0432\u0442\u0440\u0430\u043A
    \u0442\u0443\u0440\u0438\u0441\u0442\u0430\xBB"
  _shortName: 
  _description: "\u041F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u044B \u0441 \u0440\u0430\u0441\u0442\u0430\u0449\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0430\u043C\u0438 \u0430\u0440\u043C\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u043A\u043B\u0430\u0434\u0430; \u0442\u043E\u0447\u043D\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043D\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C \u0438\u0437-\u0437\u0430
    \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F \u043A\u0430\u043A\u043E\u0439-\u043B\u0438\u0431\u043E
    \u044D\u0442\u0438\u043A\u0435\u0442\u043A\u0438. \u0413\u043B\u0430\u0432\u043D\u043E\u0435,
    \u0447\u0442\u043E \u0441\u0440\u043E\u043A \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438
    \u0432\u0440\u043E\u0434\u0435 \u0431\u044B \u0435\u0449\u0451 \u043D\u0435 \u0438\u0441\u0442\u0451\u043A."
