  itemName: "\u042D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043D\u0430\u043F\u0438\u0442\u043E\u043A \xAB\u0421\u0442\u0430\u043B\u043A\u0435\u0440\xBB"
  shortName: 
  description: "\u0427\u0430\u0441\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0430\u043C\u0438 \u0432 \u043C\u043D\u043E\u0433\u043E\u0434\u043D\u0435\u0432\u043D\u044B\u0445
    \u043F\u043E\u0445\u043E\u0434\u0430\u0445, \u043A\u043E\u0433\u0434\u0430 \u043D\u0435\u0442
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C\u0441\u044F
    \u0438 \u043E\u0442\u0434\u043E\u0445\u043D\u0443\u0442\u044C. \u041D\u0430\u043F\u0438\u0442\u043E\u043A
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u043B\u0435\u0433\u043A\u043E\u0443\u0441\u0432\u0430\u0438\u0432\u0430\u0435\u043C\u044B\u0435
    \u0443\u0433\u043B\u0435\u0432\u043E\u0434\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u0440\u0435\u043F\u0430\u0440\u0430\u0442\u044B, \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0435
    \u0432\u044B\u0431\u0440\u043E\u0441 \u0430\u0434\u0440\u0435\u043D\u0430\u043B\u0438\u043D\u0430
    \u0432 \u043A\u0440\u043E\u0432\u044C."
