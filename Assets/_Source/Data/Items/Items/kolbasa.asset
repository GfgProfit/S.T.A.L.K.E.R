  itemName: "\u041A\u043E\u043B\u0431\u0430\u0441\u0430 \xAB\u0414\u0438\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F\xBB"
  shortName: 
  description: "\u0427\u0430\u0441\u0442\u043E \u0437\u0430 \u043D\u0435\u0438\u043C\u0435\u043D\u0438\u0435\u043C
    \u043B\u0443\u0447\u0448\u0435\u0433\u043E, \u044D\u0442\u0430 \u043A\u043E\u043B\u0431\u0430\u0441\u0430
    \u2014 \u0441\u043C\u0435\u0441\u044C \u043A\u0443\u0440\u044F\u0442\u0438\u043D\u044B
    \u0438 \u0441\u043E\u0435\u0432\u043E\u0433\u043E \u0437\u0430\u043C\u0435\u043D\u0438\u0442\u0435\u043B\u044F
    \u2014 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0437\u0430\u0432\u0442\u0440\u0430\u043A\u043E\u043C,
    \u043E\u0431\u0435\u0434\u043E\u043C \u0438 \u0443\u0436\u0438\u043D\u043E\u043C
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0430. \u0418\u0437-\u0437\u0430 \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u043D\u0442\u043E\u0432
    \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0434\u043E\u043B\u0433\u043E
    \u043D\u0435 \u043F\u043E\u0440\u0442\u0438\u0442\u0441\u044F."
