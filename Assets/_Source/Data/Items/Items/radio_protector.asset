  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: radio_protector
  m_EditorClassIdentifier: 
  _itemName: "\u0420\u0430\u0434\u0438\u043E\u043F\u0440\u043E\u0442\u0435\u043A\u0442\u043E\u0440"
  _shortName: 
  _description: "\u0420\u0430\u0434\u0438\u043E\u043F\u0440\u043E\u0442\u0435\u043A\u0442\u043E\u0440
    \xAB\u0418\u043D\u0434\u0440\u0430\u043B\u0438\u043D-\u0411190\xBB \u0432\u0445\u043E\u0434\u0438\u043B
    \u0432 \u0441\u043E\u0441\u0442\u0430\u0432 \u043B\u0438\u0447\u043D\u044B\u0445
    \u0430\u043F\u0442\u0435\u0447\u0435\u043A \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u043E\u0432
    \u0410\u042D\u0421. \u041F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0432 \u0417\u043E\u043D\u0435
    \u043A\u0430\u043A \u0437\u0430\u043C\u0435\u043D\u0430 \u0438\u0437\u043B\u0438\u0448\u043D\u0435
    \u0442\u043E\u043A\u0441\u0438\u0447\u043D\u043E\u043C\u0443 \u0446\u0438\u0441\u0442\u0430\u043C\u0438\u043D\u0443
    \u0433\u0438\u0434\u0440\u043E\u0445\u043B\u043E\u0440\u0438\u0434\u0430 (\u0420\u04211).
    \u0423\u043C\u0435\u043D\u044C\u0448\u0430\u0435\u0442 \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
    \u0433\u0430\u043C\u043C\u0430-\u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0442\u043A\u0430\u043D\u0438 \u0436\u0438\u0432\u043E\u0433\u043E
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0430. \u0414\u0430\u043D\u043D\u044B\u0439
    \u043F\u0440\u0435\u043F\u0430\u0440\u0430\u0442 \u0436\u0435\u043B\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u043F\u0440\u0435\u0432\u0435\u043D\u0442\u0438\u0432\u043D\u043E,
    \u0434\u043E \u043E\u0431\u043B\u0443\u0447\u0435\u043D\u0438\u044F, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u043E\u043D \u043D\u0435 \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E\u0433\u043E \u044D\u0444\u0444\u0435\u043A\u0442\u0430.
    \u041E\u0431\u043B\u0430\u0434\u0430\u0435\u0442 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C."
