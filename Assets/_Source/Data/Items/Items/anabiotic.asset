  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: anabiotic
  m_EditorClassIdentifier: 
  _itemId: 1118f1a5cbebd3f41b64721b0a766c06
  _itemName: "\u0410\u043D\u0430\u0431\u0438\u043E\u0442\u0438\u043A"
  _shortName: 
  _description: "\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0435\u043F\u0430\u0440\u0430\u0442, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0439
    \u0434\u043B\u044F \u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F, \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
    \u0432 \u0417\u043E\u043D\u0435. \u0412\u0445\u043E\u0434\u044F\u0449\u0438\u0439
    \u0432 \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u043F\u0440\u0435\u043F\u0430\u0440\u0430\u0442\u0430
    \u0442\u0435\u0442\u0440\u0430\u0434\u043E\u0442\u043E\u043A\u0441\u0438\u043D,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0430\u043A \xAB\u043F\u043E\u0440\u043E\u0448\u043E\u043A
    \u0437\u043E\u043C\u0431\u0438\xBB, \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442
    \u043F\u043E\u043B\u043D\u044B\u0439 \u043F\u0430\u0440\u0430\u043B\u0438\u0447
    \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u043D\u0435\u0440\u0432\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B; \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u044D\u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C
    \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435 \u0432\u043D\u0435 \u0443\u043A\u0440\u044B\u0442\u0438\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0432\u044B\u0431\u0440\u043E\u0441\u0430.
    \u041F\u0440\u0435\u043F\u0430\u0440\u0430\u0442 \u043D\u0435 \u0438\u0441\u043F\u044B\u0442\u044B\u0432\u0430\u043B\u0441\u044F
    \u0432 \u043F\u043E\u043B\u0435\u0432\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
    \u0438 \u043D\u0435 \u043F\u0440\u043E\u0448\u0451\u043B \u043A\u043B\u0438\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0439, \u0447\u0442\u043E \u0441\u0442\u0430\u0432\u0438\u0442
    \u043F\u043E\u0434 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435 \u0435\u0433\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0437\u0430\u0434\u0443\u043C\u0430\u0442\u044C\u0441\u044F
    \u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u043F\u043E\u0431\u043E\u0447\u043D\u044B\u0445
    \u044D\u0444\u0444\u0435\u043A\u0442\u0430\u0445."
