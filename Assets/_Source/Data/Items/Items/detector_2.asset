  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: detector_2
  m_EditorClassIdentifier: 
  itemName: "\u0414\u0435\u0442\u0435\u043A\u0442\u043E\u0440 \xAB\u041C\u0435\u0434\u0432\u0435\u0434\u044C\xBB"
  shortName: "\u041C\u0435\u0434\u0432\u0435\u0434\u044C"
  description: "\u0414\u0435\u0442\u0435\u043A\u0442\u043E\u0440 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438 \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F. \u0421\u043D\u0430\u0431\u0436\u0451\u043D
    \u043B\u043E\u043A\u0430\u0442\u043E\u0440\u043E\u043C \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439 \u0438 \u0441\u0432\u0435\u0442\u043E\u0434\u0438\u043E\u0434\u043D\u044B\u043C
    \u0442\u0430\u0431\u043B\u043E \u0434\u043B\u044F \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u043D\u0430
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442, \u043F\u0440\u0438\u0447\u0451\u043C
    \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0442\u044C \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u044B,
    \u043D\u043E \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0434\u043E \u043D\u0438\u0445.
    \u0420\u0435\u0436\u0438\u043C \u043F\u043E\u0438\u0441\u043A\u0430 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432
    \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0434\u043D\u044F\u0442\u0438\u0435\u043C
    \u043A\u0440\u044B\u0448\u043A\u0438-\u0430\u043D\u0442\u0435\u043D\u043D\u044B
    \u043D\u0430 \u043B\u0438\u0446\u0435\u0432\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0435
    \u043F\u0440\u0438\u0431\u043E\u0440\u0430. \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0443\u0436\u0435 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0443\u0441\u0442\u0430\u0440\u0435\u0432\u0448\u0438\u0439
    \u0441\u043F\u0438\u0441\u043E\u043A \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0435\u043C\u044B\u0445
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432 \u0432\u0448\u0438\u0442
    \u0432 \u043F\u0440\u0438\u0431\u043E\u0440 \u043D\u0430\u043C\u0435\u0440\u0442\u0432\u043E
    \u2014 \u043D\u0430 \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u043D\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435."
