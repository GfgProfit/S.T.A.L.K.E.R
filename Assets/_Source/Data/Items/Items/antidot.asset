  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: antidot
  m_EditorClassIdentifier: 
  _itemName: "\u0410\u043D\u0442\u0438\u0434\u043E\u0442"
  _shortName: 
  _description: "\u041F\u0440\u0435\u043F\u0430\u0440\u0430\u0442 \xAB\u0410\u043D\u0442\u0438\u0442\u043E\u043A\u0441\u0438\u043A\u0430\u043D\u0442
    \u0418\u041F2\xBB \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0441\u043E\u0431\u043E\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441
    \u0430\u043D\u0442\u0438\u0434\u043E\u0442\u043E\u0432: \u043C\u0435\u0442\u043E\u043A\u043B\u043E\u043F\u0440\u0430\u043C\u0438\u0434\u0430,
    \u043F\u0438\u0440\u0438\u0434\u043E\u043A\u0441\u0438\u043D\u0430, \u0442\u0438\u0430\u043C\u0438\u043D\u0430,
    \u0440\u0438\u0431\u043E\u043A\u0441\u0438\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445.
    \u0412\u0432\u043E\u0434\u0438\u0442 \u0432 \u043A\u0440\u043E\u0432\u044C \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0430,
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0435 \u0440\u0430\u0437\u043B\u0430\u0433\u0430\u0442\u044C
    \u0431\u0435\u043B\u043A\u043E\u0432\u044B\u0435 \u044F\u0434\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0430\u0431\u0441\u043E\u0440\u0431\u0435\u043D\u0442\u044B \u0441\u0438\u043D\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u044F\u0434\u043E\u0432. \u041E\u0441\u043E\u0431\u043E\u0439 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C\u044E
    \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u043E\u0432
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442\u0441\u044F
    \u043D\u0430 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0433\u0430\u0437 \u0438
    \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D. \u041E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C."
