  m_Name: medkit_t3
  m_EditorClassIdentifier: 
  _itemName: "\u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0430\u043F\u0442\u0435\u0447\u043A\u0430"
  _shortName: 
  _description: "\u041C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0439
    \u043D\u0430\u0431\u043E\u0440, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0439
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0434\u043B\u044F
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u0417\u043E\u043D\u044B.
    \u0421\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430
    \u043A\u0430\u043A \u0434\u043B\u044F \u0437\u0430\u0436\u0438\u0432\u043B\u0435\u043D\u0438\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0442\u0440\u0430\u0432\u043C,
    \u0442\u0430\u043A \u0438 \u0434\u043B\u044F \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u043B\u0443\u0447\u0435\u0432\u043E\u0439
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0434\u0440\u0443\u0433\u0438\u0445 \u043D\u0430\u0431\u043E\u0440\u043E\u0432,
    \u0432 \u044D\u0442\u043E\u043C \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u0439\u0442\u0438
    \xAB\u0412\u0438\u043A\u0430\u0441\u043E\u043B\xBB, \xAB\u0411\u0430\u0442\u0438\u043B\u043E\u043B\xBB
    \u0438 \u0421-\u043D\u0430\u0444\u0442\u0438\u0437\u0438\u043D."
