  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: antirad
  m_EditorClassIdentifier: 
  itemName: "\u041F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0430\u0434\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043F\u0440\u0435\u043F\u0430\u0440\u0430\u0442"
  shortName: 
  description: "\u041F\u0440\u0435\u043F\u0430\u0440\u0430\u0442 \u0440\u0430\u0434\u0438\u043E\u0437\u0430\u0449\u0438\u0442\u043D\u043E\u0433\u043E
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \xAB\u041C\u0435\u043A\u0441\u0430\u043C\u0438\u043D\xBB,
    \u0448\u0438\u0440\u043E\u043A\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0451\u043D\u043D\u044B\u0439
    \u043D\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438 \u0417\u043E\u043D\u044B.
    \u041F\u0440\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0438
    \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442 \u0441\u0443\u0436\u0435\u043D\u0438\u0435
    \u043F\u0435\u0440\u0438\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u043E\u0432\u0435\u043D\u043E\u0441\u043D\u044B\u0445 \u0441\u043E\u0441\u0443\u0434\u043E\u0432
    \u0438 \u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434\u043D\u043E\u0435 \u0433\u043E\u043B\u043E\u0434\u0430\u043D\u0438\u0435,
    \u0447\u0442\u043E \u0432 \u0434\u0430\u043D\u043D\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043E\u043C
    \u043F\u0440\u043E\u0444\u0438\u043B\u0430\u043A\u0442\u0438\u043A\u0438 \u0438
    \u043B\u0435\u0447\u0435\u043D\u0438\u044F \u043B\u0443\u0447\u0435\u0432\u043E\u0439
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u0425\u043E\u0440\u043E\u0448\u043E
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u043F\u043E\u0434\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u043C
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E\u043C \u043B\u044E\u0434\u0435\u0439;
    \u0432 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0445 \u0441\u043B\u0443\u0447\u0430\u044F\u0445
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B \u043B\u0451\u0433\u043A\u0430\u044F
    \u0442\u043E\u0448\u043D\u043E\u0442\u0430, \u0433\u043E\u043B\u043E\u0432\u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0435,
    \u0431\u043E\u043B\u0438, \u0440\u0435\u0436\u0435 \u0440\u0432\u043E\u0442\u0430."
