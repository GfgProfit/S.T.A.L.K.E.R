  itemName: "\u0414\u0435\u0442\u0435\u043A\u0442\u043E\u0440 \xAB\u0412\u0435\u043B\u0435\u0441\xBB"
  shortName: "\u0412\u0435\u043B\u0435\u0441"
  description: "\u0414\u0435\u0442\u0435\u043A\u0442\u043E\u0440-\u0441\u043A\u0430\u043D\u0435\u0440
    \u043D\u043E\u0432\u043E\u0433\u043E \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u043C\u0438.
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0442\u0440\u0451\u043C
    \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u043D\u044B\u043C
    \u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u043A\u0430\u043C\u0435\u0440\u0430\u043C \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u0435\u0442\u0435\u043A\u0442\u043E\u0440\u0430 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C
    \u044D\u043A\u0440\u0430\u043D\u0435. \u0421\u043F\u043E\u0441\u043E\u0431\u0435\u043D
    \u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u0435
    \u0438 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0430\u043D\u043E\u043C\u0430\u043B\u0438\u0439.
    \u0420\u0435\u0436\u0438\u043C \u043F\u043E\u0438\u0441\u043A\u0430 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432
    \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0434\u043D\u044F\u0442\u0438\u0435\u043C
    \u0438\u043D\u0434\u0438\u043A\u0430\u0442\u043E\u0440\u0430-\u0442\u0430\u0431\u043B\u043E
    \u043D\u0430 \u043B\u0438\u0446\u0435\u0432\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0435
    \u043F\u0440\u0438\u0431\u043E\u0440\u0430; \u0432 \u0434\u0430\u043D\u043D\u043E\u043C
    \u0440\u0435\u0436\u0438\u043C\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0442\u044C \u0432\u0441\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u043D\u0430\u0443\u043A\u0435
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u044B."
