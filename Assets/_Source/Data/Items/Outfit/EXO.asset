  m_Name: EXO
  m_EditorClassIdentifier: 
  _itemId: fc44f8ea89d96984b971ba0357b92b32
  _itemName: "\u042D\u043A\u0437\u043E\u0441\u043A\u0435\u043B\u0435\u0442"
  _shortName: "\u042D\u043A\u0437\u043E\u0441\u043A\u0435\u043B\u0435\u0442"
  _description: "\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437\u0435\u0446 \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u044D\u043A\u0437\u043E\u0441\u043A\u0435\u043B\u0435\u0442\u0430. \u0412 \u0441\u0435\u0440\u0438\u0439\u043D\u043E\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E \u043D\u0435
    \u043F\u043E\u0448\u0451\u043B \u0432\u0432\u0438\u0434\u0443 \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E
    \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0441\u0435\u0431\u0435\u0441\u0442\u043E\u0438\u043C\u043E\u0441\u0442\u0438
    \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u0433\u0440\u0435\u0445\u043E\u0432
    \u0432 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u044D\u0442\u043E,
    \u0438\u0437-\u0437\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0442\u044C
    \u043C\u043E\u0431\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044F
    \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0441\u043F\u0440\u043E\u0441\u043E\u043C
    \u0438 \u043F\u043E\u0442\u043E\u043C\u0443 \u043D\u0435\u0433\u043B\u0430\u0441\u043D\u043E
    \u0432\u044B\u043F\u0443\u0441\u043A\u0430\u0435\u0442\u0441\u044F \u043C\u0430\u043B\u044B\u043C\u0438
    \u043F\u0430\u0440\u0442\u0438\u044F\u043C\u0438 \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
    \u0423\u043A\u0440\u0430\u0438\u043D\u044B. \u041E\u0441\u043D\u0430\u0449\u0451\u043D
    \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u043C \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u043E\u043C
    \u0434\u043B\u044F \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432."
