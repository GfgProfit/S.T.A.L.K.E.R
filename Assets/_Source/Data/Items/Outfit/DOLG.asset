  itemName: "\u041F\u04215-\u041C \xAB\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0430\u044F
    \u0437\u0430\u0449\u0438\u0442\u0430\xBB"
  shortName: "\u041F\u04215-\u041C"
  description: "\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u043C\u043E\u0434\u0435\u043B\u044C \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D\u0430
    \xAB\u0414\u043E\u043B\u0433\u0430\xBB. \u0411\u043E\u043B\u044C\u0448\u0435
    \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442 \u043D\u043E\u0432\u043E\u0431\u0440\u0430\u043D\u0446\u0430\u043C
    \u0438\u0437 \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0440\u0438\u0432\u044B\u043A\u043B\u0438 \u043A \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043B\u0451\u0433\u043A\u0438\u043C \u043A\u043E\u0441\u0442\u044E\u043C\u0430\u043C.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0441\u0435\u0440\u0438\u0438
    \u041F\u04213, \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0435\u0442
    \u0445\u043E\u0440\u043E\u0448\u0443\u044E \u0437\u0430\u0449\u0438\u0442\u0443
    \u043E\u0442 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0438 \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043D\u0443\u044E \u043F\u0443\u043B\u044E.
    \u041A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u044B \u0434\u043B\u044F
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432 \u043D\u0435 \u043F\u0440\u0435\u0434\u0443\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u044B,
    \u0437\u0430\u0442\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u0430 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430
    \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u0432\u0441\u043F\u043E\u043C\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C."
