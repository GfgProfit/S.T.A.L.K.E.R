  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: HELM TACTIC
  m_EditorClassIdentifier: 
  _itemName: "\u0422\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0448\u043B\u0435\u043C"
  _shortName: "\u0422\u0430\u043A\u0442"
  _description: "\u0417\u0430\u043F\u0430\u0434\u043D\u044B\u0439 \u043E\u0431\u0440\u0430\u0437\u0435\u0446
    \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0448\u043B\u0435\u043C\u0430,
    \u043B\u0438\u0448\u0451\u043D\u043D\u044B\u0439 \u043A\u0430\u043A\u043E\u0439-\u043B\u0438\u0431\u043E
    \u043C\u0430\u0440\u043A\u0438\u0440\u043E\u0432\u043A\u0438. \u041F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u0434\u043B\u044F \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440\u0430 \u043F\u043E\u0434\u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u043C \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C
    \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u043F\u0440\u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0435 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0439
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u043E\u0439 \xAB\u043D\u0430\u0447\u0438\u043D\u043A\u0438\xBB.
    \u041E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0441\u044F \u0443\u0441\u0438\u043B\u0435\u043D\u043D\u043E\u0439
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0435\u0439; \u043A\u0440\u043E\u043C\u0435
    \u0442\u043E\u0433\u043E, \u043E\u0441\u043D\u0430\u0449\u0451\u043D \u043C\u043D\u043E\u0433\u043E\u0441\u043B\u043E\u0439\u043D\u043E\u0439
    \u043A\u0435\u0432\u043B\u0430\u0440\u043E\u0432\u043E\u0439 \u0437\u0430\u0449\u0438\u0442\u043E\u0439,
    \u0440\u0435\u0441\u043F\u0438\u0440\u0430\u0442\u043E\u0440\u043E\u043C \u0438
    \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u043C \u043D\u043E\u0447\u043D\u043E\u0433\u043E
    \u0432\u0438\u0434\u0435\u043D\u0438\u044F."
