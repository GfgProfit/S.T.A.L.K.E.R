  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: MILITARY
  m_EditorClassIdentifier: 
  _itemId: 936e4304ca1bbea4493cd09670b17d94
  _itemName: "\u0411\u0440\u043E\u043D\u0435\u043A\u043E\u0441\u0442\u044E\u043C
    \xAB\u0411\u0443\u043B\u0430\u0442\xBB"
  _shortName: "\u0411\u0443\u043B\u0430\u0442"
  _description: "\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u0430\u0440\u043C\u0435\u0439\u0441\u043A\u0438\u0439 \u0431\u0440\u043E\u043D\u0435\u043A\u043E\u0441\u0442\u044E\u043C
    \u0434\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0448\u0442\u0443\u0440\u043C\u043E\u0432\u044B\u0445 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439
    \u0432 \u0437\u043E\u043D\u0430\u0445 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438. \u041A\u043E\u043C\u043F\u043E\u043D\u0435\u043D\u0442\u044B:
    \u0442\u044F\u0436\u0451\u043B\u044B\u0439 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442
    \u0441\u0435\u0440\u0438\u0438 \u041F\u0421\u0417-12\u043F, \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D
    \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0437\u0430\u0449\u0438\u0442\u044B
    \u0438 \u043A\u043E\u043C\u043F\u0435\u043D\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043A\u043E\u0441\u0442\u044E\u043C. \u041F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0432\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u043D\u0443\u044E \u0437\u0430\u0449\u0438\u0442\u0443
    \u043E\u0442 \u043F\u0443\u043B\u044C \u0438 \u043E\u0441\u043A\u043E\u043B\u043A\u043E\u0432,
    \u0438 \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0443\u0434\u043E\u0431\u0435\u043D,
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442
    \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0441\u0442\u044C \u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044F.
    \u041D\u0435 \u043E\u0441\u043D\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u0430\u043C\u0438
    \u0434\u043B\u044F \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432."
