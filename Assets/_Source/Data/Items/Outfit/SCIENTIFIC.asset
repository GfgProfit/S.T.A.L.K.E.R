  m_Name: SCIENTIFIC
  m_EditorClassIdentifier: 
  _itemId: 64ac637f9cd02844ebe09a10b92cd2f0
  _itemName: "\u041A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D \xAB\u0421\u0415\u0412\u0410\xBB"
  _shortName: "\u0421\u0415\u0412\u0410"
  _description: "\u041F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u043C\u0430\u044F
    \u0432 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u043A\u0438\u0435\u0432\u0441\u043A\u0438\u0445
    \u043E\u0431\u043E\u0440\u043E\u043D\u043D\u044B\u0445 \u041D\u0418\u0418 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u0430
    \u043A\u0443\u0441\u0442\u0430\u0440\u043D\u044B\u043C \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D\u0430\u043C
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u043E\u0432. \u0425\u043E\u0442\u044F
    \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0439 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442
    \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043D\u0443\u044E
    \u043F\u0443\u043B\u044E, \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0437\u0430\u0449\u0438\u0442\u044B
    \u043E\u0442 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u0445 \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439
    \u0438 \u0440\u0430\u0434\u0438\u0430\u0446\u0438\u0438 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043D\u0435\u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0434\u0451\u043D\u043D\u043E\u0439.
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043C\u043E\u0434\u0435\u0440\u043D\u0438\u0437\u0430\u0446\u0438\u0438
    \u0438 \u0434\u0432\u0430 \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0445
    \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u0430 \u0434\u043B\u044F
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432 \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u044D\u0442\u0443 \u043C\u043E\u0434\u0435\u043B\u044C \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0439
    \u0441\u0440\u0435\u0434\u0438 \u043E\u043F\u044B\u0442\u043D\u044B\u0445 \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u043E\u0432."
