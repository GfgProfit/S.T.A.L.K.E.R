  itemName: "\u0428\u043B\u0435\u043C \xAB\u0417\u0430\u0441\u043B\u043E\u043D\xBB"
  shortName: "\u0417\u0430\u0441\u043B\u043E\u043D"
  description: "\u041B\u0451\u0433\u043A\u0438\u0439 \u0448\u043B\u0435\u043C \u0441
    \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0447\u043D\u044B\u043C \u0437\u0430\u0431\u0440\u0430\u043B\u043E\u043C,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0439
    \u0434\u043B\u044F \u0437\u0430\u0449\u0438\u0442\u044B \u043B\u0438\u0446\u0430
    \u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439. \u0421\u0443\u0434\u044F
    \u043F\u043E \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D
    \u0442\u0435\u043C \u0436\u0435 \u043E\u0431\u043E\u0440\u043E\u043D\u043D\u044B\u043C
    \u041D\u0418\u0418, \u0447\u0442\u043E \u0438 \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D
    \xAB\u0421\u0415\u0412\u0410\xBB \u2014 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0434\u043B\u044F \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F
    \u0432 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0442\u0435 \u0441 \u0430\u0440\u043C\u0435\u0439\u0441\u043A\u0438\u043C\u0438
    \u0437\u0430\u0449\u0438\u0442\u043D\u044B\u043C\u0438 \u043A\u043E\u0441\u0442\u044E\u043C\u0430\u043C\u0438."
