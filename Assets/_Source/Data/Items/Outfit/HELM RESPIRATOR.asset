  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: HELM RESPIRATOR
  m_EditorClassIdentifier: 
  _itemId: ee2d0d462cb46484d9890047e22b55c5
  _itemName: "\u041F\u0440\u043E\u0442\u0438\u0432\u043E\u0433\u0430\u0437"
  _shortName: "\u041F\u0440\u043E\u0442\u0438\u0432\u043E\u0433\u0430\u0437"
  _description: "\u0421\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0433\u0430\u0437, \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0439
    \u0434\u043B\u044F \u0444\u0438\u043B\u044C\u0442\u0440\u0430\u0446\u0438\u0438
    \u0438\u0437 \u0432\u043E\u0437\u0434\u0443\u0445\u0430 \u0440\u0430\u0434\u0438\u043E\u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043F\u044B\u043B\u0438 \u0438 \u043E\u0442\u0440\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0445
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432. \u0428\u0438\u0440\u043E\u043A\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u043A\u0430\u043A
    \u043D\u043E\u0432\u0438\u0447\u043A\u0430\u043C\u0438, \u0442\u0430\u043A \u0438
    \u0432\u0435\u0442\u0435\u0440\u0430\u043D\u0430\u043C\u0438 \u0432\u0441\u0435\u0445
    \u0433\u0440\u0443\u043F\u043F\u0438\u0440\u043E\u0432\u043E\u043A \u0432\u0432\u0438\u0434\u0443
    \u0441\u0432\u043E\u0435\u0439 \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043D\u0435\u0437\u0430\u043C\u0435\u043D\u0438\u043C\u043E\u0441\u0442\u0438.
    \u041D\u0435 \u043E\u0441\u043D\u0430\u0449\u0451\u043D \u0437\u0430\u0449\u0438\u0442\u043E\u0439
    \u043E\u0442 \u043F\u0443\u043B\u044C, \u043E\u0441\u043A\u043E\u043B\u043A\u043E\u0432
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439."
