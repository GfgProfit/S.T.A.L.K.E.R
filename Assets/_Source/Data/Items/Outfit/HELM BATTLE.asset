  m_Name: HELM BATTLE
  m_EditorClassIdentifier: 
  itemName: "\u0428\u043B\u0435\u043C \xAB\u0421\u0444\u0435\u0440\u0430 \u041C12\xBB"
  shortName: "\u0421\u041C12"
  description: "\u041E\u0442\u0434\u0435\u043B\u0430\u043D\u043D\u044B\u0439 \u0442\u043A\u0430\u043D\u044C\u044E
    \u0430\u043B\u044E\u043C\u0438\u043D\u0438\u0435\u0432\u043E-\u0442\u0438\u0442\u0430\u043D\u043E\u0432\u044B\u0439
    \u0448\u043B\u0435\u043C \u0441 \u043A\u0430\u0440\u043C\u0430\u043D\u0430\u043C\u0438
    \u0434\u043B\u044F \u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0445 \u0431\u0440\u043E\u043D\u0435\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432
    \u0438 \u0431\u0440\u043E\u043D\u0435\u043C\u0430\u0441\u043A\u043E\u0439. \u041E\u0431\u044B\u0447\u043D\u043E
    \u043F\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0432
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0442\u0435 \u0441 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442\u0430\u043C\u0438
    \u043A\u043B\u0430\u0441\u0441\u0430 \u041F\u04213 \u0434\u043B\u044F \u0441\u043F\u0435\u0446\u043D\u0430\u0437\u0430.
    \u0414\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0435\u043D
    \u0432 \u0417\u043E\u043D\u0435 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0440\u0435\u0441\u043F\u0438\u0440\u0430\u0442\u043E\u0440\u0443 \u0438 \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u043E\u043C\u0443
    \u043F\u0440\u0438\u0431\u043E\u0440\u0443 \u043D\u043E\u0447\u043D\u043E\u0433\u043E
    \u0432\u0438\u0434\u0435\u043D\u0438\u044F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0445\u043E\u0440\u043E\u0448\u0435\u0439 \u0437\u0430\u0449\u0438\u0442\u0435
    \u0433\u043E\u043B\u043E\u0432\u044B. \u041F\u0440\u0435\u0434\u0443\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u0430
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u0438\u043A\u0438."
