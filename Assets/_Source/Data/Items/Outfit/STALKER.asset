  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: STALKER
  m_EditorClassIdentifier: 
  _itemName: "\u041A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D \xAB\u0417\u0430\u0440\u044F\xBB"
  _shortName: "\u0417\u0430\u0440\u044F"
  _description: "\u041F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u043C\u044B\u0439
    \u043D\u0430\u0440\u043E\u0434\u043D\u044B\u043C\u0438 \u0443\u043C\u0435\u043B\u044C\u0446\u0430\u043C\u0438
    \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0430
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0441\u043E\u0431\u043E\u0439
    \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0435 \u0434\u0432\u0443\u0445\u0441\u043B\u043E\u0439\u043D\u043E\u0439
    \u043F\u0440\u043E\u0440\u0435\u0437\u0438\u043D\u0435\u043D\u043D\u043E\u0439
    \u0442\u043A\u0430\u043D\u0438 \u0441 \u043F\u043B\u0435\u043A\u0441\u0438\u0433\u043B\u0430\u0441\u043E\u0432\u043E\u0439
    \u043F\u0440\u043E\u043A\u043B\u0430\u0434\u043A\u043E\u0439 \u0438 \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442\u0430. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442
    \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u0442\u0441\u044F \u0434\u0430\u0436\u0435
    \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043D\u043E\u0439 \u043F\u0443\u043B\u0435\u0439,
    \u043A\u043E\u0441\u0442\u044E\u043C \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0451\u043D
    \u0438\u0437-\u0437\u0430 \u0434\u0435\u0448\u0435\u0432\u0438\u0437\u043D\u044B
    \u0438 \u0448\u0438\u0440\u043E\u043A\u0438\u0445 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0435\u0439
    \u0434\u043B\u044F \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u044F. \u041E\u0441\u043D\u0430\u0449\u0451\u043D
    \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u043C\u0438 \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u0430\u043C\u0438
    \u0434\u043B\u044F \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432."
