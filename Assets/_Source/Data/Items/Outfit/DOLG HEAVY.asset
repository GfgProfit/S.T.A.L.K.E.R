  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: DOLG HEAVY
  m_EditorClassIdentifier: 
  _itemName: "\u041F\u0421\u0417-9\u0434 \xAB\u0411\u0440\u043E\u043D\u044F \u201E\u0414\u043E\u043B\u0433\u0430\u201C\xBB"
  _shortName: "\u041F\u0421\u0417-9\u0434"
  _description: "\u0420\u0430\u043D\u043D\u044F\u044F \u043C\u043E\u0434\u0435\u043B\u044C
    \u043A\u043E\u043C\u0431\u0438\u043D\u0435\u0437\u043E\u043D\u0430 \xAB\u0414\u043E\u043B\u0433\u0430\xBB
    \u2014 \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442 \u0441\u043F\u0435\u0446\u043D\u0430\u0437\u0430
    \u0441\u0435\u0440\u0438\u0438 \u041F\u04213-9, \u043F\u0440\u0438\u0441\u043F\u043E\u0441\u043E\u0431\u043B\u0435\u043D\u043D\u044B\u0439
    \u0434\u043B\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u0417\u043E\u043D\u044B.
    \u0421\u043F\u043E\u0441\u043E\u0431\u0435\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u044C
    \u043E\u0442 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043D\u043E\u0439 \u043F\u0443\u043B\u0438,
    \u043D\u043E \u043E\u0447\u0435\u043D\u044C \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043E\u043A
    \u0438 \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0435\u0442
    \u0437\u0430\u0449\u0438\u0442\u0443 \u043E\u0442 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439. \u0423\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430
    \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u043E\u0432 \u0434\u043B\u044F
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432 \u043D\u0435 \u043F\u0440\u0435\u0434\u0443\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u0430,
    \u0437\u0430\u0442\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u043E\u0441\u043D\u0430\u0449\u0435\u043D\u0438\u0435
    \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u043C\u0438 \u0432\u0441\u043F\u043E\u043C\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u043C\u0438."
