  m_Name: CS HEAVY
  m_EditorClassIdentifier: 
  itemName: "\u0411\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442 \u0427\u041D-3\u0430"
  shortName: "\u0427\u041D-3\u0430"
  description: "\u041D\u0435\u043A\u043E\u0433\u0434\u0430 \u044D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0448\u0442\u0430\u0442\u043D\u0430\u044F \u044D\u043A\u0438\u043F\u0438\u0440\u043E\u0432\u043A\u0430
    \u0448\u0442\u0443\u0440\u043C\u043E\u0432\u044B\u0445 \u043E\u0442\u0440\u044F\u0434\u043E\u0432
    \xAB\u0427\u0438\u0441\u0442\u043E\u0433\u043E \u043D\u0435\u0431\u0430\xBB.
    \u0423\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0438\u0435 \u0434\u0430\u043D\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u0438\u0440\u043E\u0432\u043A\u0438 \u0441\u0442\u0430\u043B\u043E
    \u0434\u043E\u0445\u043E\u0434\u0447\u0438\u0432\u044B\u043C \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435\u043C
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u043E\u0442\u043B\u0438\u0447\u043D\u043E\u0435
    \u0441\u043D\u0430\u0440\u044F\u0436\u0435\u043D\u0438\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C \u0432
    \u0417\u043E\u043D\u0435. \u0414\u0430\u043D\u043D\u044B\u0439 \u0437\u0430\u0449\u0438\u0442\u043D\u044B\u0439
    \u043A\u043E\u0441\u0442\u044E\u043C \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043D\u0443\u044E \u043F\u0443\u043B\u044E,
    \u043D\u043E \u0438 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0435\u0442
    \u0445\u043E\u0440\u043E\u0448\u0443\u044E \u0437\u0430\u0449\u0438\u0442\u0443
    \u043E\u0442 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u0445 \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439.
    \u041E\u0441\u043D\u0430\u0449\u0451\u043D \u0432\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u043C
    \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u043E\u043C \u0434\u043B\u044F
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432."
