  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: NOVICE
  m_EditorClassIdentifier: 
  _itemName: "\u041A\u043E\u0436\u0430\u043D\u044B\u0439 \u043F\u043B\u0430\u0449"
  _shortName: "\u041F\u043B\u0430\u0449"
  _description: "\u041E\u0431\u044B\u0447\u043D\u044B\u0439 \u043F\u043B\u0430\u0449
    \u0438\u0437 \u0447\u0451\u0440\u043D\u043E\u0439 \u043A\u043E\u0436\u0438. \u0417\u0430\u043C\u0435\u0442\u043D\u043E\u0439
    \u0437\u0430\u0449\u0438\u0442\u044B \u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044E
    \u043D\u0435 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0435\u0442.
    \u0420\u0430\u0437\u0432\u0435 \u0447\u0442\u043E \u043D\u0435 \u0434\u0430\u0441\u0442
    \u0437\u0430\u043C\u0451\u0440\u0437\u043D\u0443\u0442\u044C \u043D\u043E\u0447\u044C\u044E
    \u0438 \u0441\u043C\u044F\u0433\u0447\u0438\u0442 \u0443\u043A\u0443\u0441 \u0441\u043B\u0435\u043F\u043E\u0433\u043E
    \u043F\u0441\u0430. \u0414\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u043D\u0435\u0443\u0434\u043E\u0431\u0435\u043D
    \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u0417\u043E\u043D\u044B,
    \u043D\u043E, \u0442\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435,
    \u0447\u0430\u0441\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0431\u0430\u043D\u0434\u0438\u0442\u0430\u043C\u0438 \u2014 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437-\u0437\u0430 \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E \u0432\u0438\u0434\u0430."
