  m_Name: SPECOPS
  m_EditorClassIdentifier: 
  _itemId: 236002c1aef38e145968ff3d3c64dc03
  _itemName: "\u0411\u0440\u043E\u043D\u0435\u043A\u043E\u0441\u0442\u044E\u043C
    \xAB\u0411\u0435\u0440\u0438\u043B\u043B-5\u041C\xBB"
  _shortName: "\u0411-5\u041C"
  _description: "\u041C\u043E\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
    \u0417\u043E\u043D\u044B \u0430\u0440\u043C\u0435\u0439\u0441\u043A\u0438\u0439
    \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442 \u0441\u0435\u0440\u0438\u0438
    \u041F\u04215 \u0441 \u0431\u0435\u0440\u0438\u043B\u043B\u0438\u0435\u0432\u044B\u043C
    \u043D\u0430\u043F\u044B\u043B\u0435\u043D\u0438\u0435\u043C. \u041F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u0434\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0448\u0442\u0443\u0440\u043C\u043E\u0432\u044B\u0445 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u0441 \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u043D\u044B\u043C
    \u0440\u0430\u0434\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C \u0444\u043E\u043D\u043E\u043C,
    \u043D\u043E \u043C\u0430\u043B\u043E\u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u0435\u043D
    \u0432 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438.
    \u041A \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0430\u043C \u043F\u043E\u043F\u0430\u0434\u0430\u0435\u0442
    \u0447\u0435\u0440\u0435\u0437 \u0432\u043E\u0435\u043D\u043D\u044B\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u0435\u043D\u044F\u044E\u0442 \u0430\u0440\u043C\u0435\u0439\u0441\u043A\u043E\u0435
    \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E \u043D\u0430 \u0445\u0430\u0431\u0430\u0440.
    \u041D\u0435 \u043E\u0441\u043D\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u043A\u043E\u043D\u0442\u0435\u0439\u043D\u0435\u0440\u0430\u043C\u0438
    \u0434\u043B\u044F \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u0432."
