  m_Name: scope_all_eotech_exps3
  m_EditorClassIdentifier: 
  _itemName: "\u0413\u043E\u043B\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0446\u0435\u043B EOTech \"XPS3-0\""
  _shortName: 
  _description: "EOTech EXPS3-0 \u2014 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u044B\u0439
    \u0433\u043E\u043B\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0446\u0435\u043B \u0437\u0430\u043F\u0430\u0434\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430 \u0432
    \u043F\u0435\u0441\u043E\u0447\u043D\u043E\u043C \u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0438.
    \u0412 \u0417\u043E\u043D\u0435 \u043F\u043E\u0434\u043E\u0431\u043D\u0430\u044F
    \u043E\u043F\u0442\u0438\u043A\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F
    \u0440\u0435\u0434\u043A\u043E \u0438 \u043E\u0431\u044B\u0447\u043D\u043E \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u043E\u0440\u0443\u0436\u0438\u0435\u043C
    \u043D\u0430\u0451\u043C\u043D\u0438\u043A\u043E\u0432 \u0438\u043B\u0438 \u0441\u043D\u0430\u0440\u044F\u0436\u0435\u043D\u0438\u0435\u043C
    \u0438\u0437 \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u043F\u043E\u0441\u0442\u0430\u0432\u043E\u043A.
    \u041F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0431\u044B\u0441\u0442\u0440\u043E
    \u043B\u043E\u0432\u0438\u0442\u044C \u0446\u0435\u043B\u044C \u043D\u0430 \u0431\u043B\u0438\u0436\u043D\u0435\u0439
    \u0438 \u0441\u0440\u0435\u0434\u043D\u0435\u0439 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0438,
    \u043D\u0435 \u043F\u0435\u0440\u0435\u043A\u0440\u044B\u0432\u0430\u044F \u043E\u0431\u0437\u043E\u0440
    \u0438 \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u044F \u0434\u043E\u043B\u0433\u043E\u0433\u043E
    \u043F\u0440\u0438\u0446\u0435\u043B\u0438\u0432\u0430\u043D\u0438\u044F. \u0425\u043E\u0440\u043E\u0448\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442 \u0434\u043B\u044F \u0448\u0442\u0443\u0440\u043C\u043E\u0432\u044B\u0445
    \u0432\u0438\u043D\u0442\u043E\u0432\u043E\u043A \u0438 \u043A\u0430\u0440\u0430\u0431\u0438\u043D\u043E\u0432,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u0438\u0445
    \u0440\u0430\u0437\u0432\u0430\u043B\u0438\u043D\u0430\u0445, \u043F\u043E\u0434\u0437\u0435\u043C\u0435\u043B\u044C\u044F\u0445
    \u0438 \u0433\u0443\u0441\u0442\u043E\u0439 \u0440\u0430\u0441\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u043F\u0438\u0442\u0430\u043D\u0438\u044F
    \u0438 \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044F,
    \u043D\u043E \u0434\u0430\u0451\u0442 \u0441\u0442\u0440\u0435\u043B\u043A\u0443
    \u0442\u043E \u0441\u0430\u043C\u043E\u0435 \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E,
    \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432 \u0417\u043E\u043D\u0435
    \u0447\u0430\u0441\u0442\u043E \u043F\u043B\u0430\u0442\u044F\u0442 \u0436\u0438\u0437\u043D\u044C\u044E."
