  m_Name: mag_45_backelite
  m_EditorClassIdentifier: 
  _itemName: "\u041C\u0430\u0433\u0430\u0437\u0438\u043D 6\u041B18 \u043D\u0430 45
    \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432 5.45x39 \u0434\u043B\u044F \u0410\u041A-74"
  _shortName: 
  _description: "6\u041B18 \u2014 \u0443\u0434\u043B\u0438\u043D\u0451\u043D\u043D\u044B\u0439
    \u043C\u0430\u0433\u0430\u0437\u0438\u043D \u043D\u0430 45 \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432
    5.45\xD739 \u043C\u043C \u0434\u043B\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043E\u0432
    \u0441\u0435\u043C\u0435\u0439\u0441\u0442\u0432\u0430 \u0410\u041A-74. \u0412
    \u0417\u043E\u043D\u0435 \u0435\u0433\u043E \u0446\u0435\u043D\u044F\u0442 \u0437\u0430
    \u043F\u0440\u043E\u0441\u0442\u043E\u0439 \u0438 \u043F\u043E\u043D\u044F\u0442\u043D\u044B\u0439
    \u043F\u043B\u044E\u0441: \u0431\u043E\u043B\u044C\u0448\u0435 \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432
    \u0434\u043E \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439 \u043F\u0435\u0440\u0435\u0437\u0430\u0440\u044F\u0434\u043A\u0438.
    \u0425\u043E\u0440\u043E\u0448\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442
    \u0434\u043B\u044F \u0437\u0430\u0442\u044F\u0436\u043D\u044B\u0445 \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u0435\u043B\u043E\u043A,
    \u0437\u0430\u0447\u0438\u0441\u0442\u043A\u0438 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u0439
    \u0438 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0439, \u0433\u0434\u0435 \u0432\u0440\u0430\u0433\u043E\u0432
    \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u0445\u043E\u0442\u0435\u043B\u043E\u0441\u044C
    \u0431\u044B. \u041F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E
    \u0441\u043E \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C
    \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u043E\u043C \u0434\u0435\u043B\u0430\u0435\u0442
    \u043E\u0440\u0443\u0436\u0438\u0435 \u0442\u044F\u0436\u0435\u043B\u0435\u0435
    \u0438 \u043C\u0435\u043D\u0435\u0435 \u0443\u0434\u043E\u0431\u043D\u044B\u043C
    \u0432 \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0438, \u0437\u0430\u0442\u043E
    \u0434\u0430\u0451\u0442 \u0441\u0442\u0440\u0435\u043B\u043A\u0443 \u043B\u0438\u0448\u043D\u0438\u0435
    \u0441\u0435\u043A\u0443\u043D\u0434\u044B \u043E\u0433\u043D\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0447\u0430\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u044E\u0442 \u0438\u0441\u0445\u043E\u0434
    \u0441\u0445\u0432\u0430\u0442\u043A\u0438."
