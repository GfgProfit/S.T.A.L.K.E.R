  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: mag_60
  m_EditorClassIdentifier: 
  _itemName: "\u041C\u0430\u0433\u0430\u0437\u0438\u043D 6\u041B31 \u043D\u0430 60
    \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432 5.45x39 \u0434\u043B\u044F \u0410\u041A-74"
  _shortName: 
  _description: "6\u041B31 \u2014 \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u0440\u044F\u0434\u043D\u044B\u0439
    \u043C\u0430\u0433\u0430\u0437\u0438\u043D \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0439
    \u0451\u043C\u043A\u043E\u0441\u0442\u0438 \u043D\u0430 60 \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432
    5.45\xD739 \u043C\u043C \u0434\u043B\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043E\u0432
    \u0441\u0435\u043C\u0435\u0439\u0441\u0442\u0432\u0430 \u0410\u041A-74. \u0412
    \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0430\u044F \u0432\u0435\u0449\u044C
    \u0446\u0435\u043D\u0438\u0442\u0441\u044F \u0443 \u0442\u0435\u0445, \u043A\u0442\u043E
    \u043D\u0435 \u043B\u044E\u0431\u0438\u0442 \u043F\u0435\u0440\u0435\u0437\u0430\u0440\u044F\u0436\u0430\u0442\u044C\u0441\u044F
    \u043F\u043E\u0441\u0440\u0435\u0434\u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u0435\u043B\u043A\u0438:
    \u043B\u0438\u0448\u043D\u0438\u0435 \u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044C
    \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432 \u0438\u043D\u043E\u0433\u0434\u0430
    \u0440\u0435\u0448\u0430\u044E\u0442 \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C
    \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442. \u041F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0434\u043E\u043B\u044C\u0448\u0435 \u0432\u0435\u0441\u0442\u0438 \u043E\u0433\u043E\u043D\u044C
    \u0438 \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u0435\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0433\u0440\u0443\u043F\u043F \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430,
    \u043D\u043E \u0434\u0435\u043B\u0430\u0435\u0442 \u043E\u0440\u0443\u0436\u0438\u0435
    \u0442\u044F\u0436\u0435\u043B\u0435\u0435, \u0437\u0430\u043C\u0435\u0442\u043D\u0435\u0435
    \u0438 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u0435\u0435
    \u043A \u0443\u0445\u043E\u0434\u0443. \u041F\u0440\u0438 \u0433\u0440\u044F\u0437\u0438,
    \u0438\u0437\u043D\u043E\u0441\u0435 \u0438\u043B\u0438 \u043F\u043B\u043E\u0445\u0438\u0445
    \u043F\u0430\u0442\u0440\u043E\u043D\u0430\u0445 \u043C\u043E\u0436\u0435\u0442
    \u043F\u043E\u0434\u0432\u0435\u0441\u0442\u0438 \u0432 \u0441\u0430\u043C\u044B\u0439
    \u043D\u0435\u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u0439 \u043C\u043E\u043C\u0435\u043D\u0442,
    \u0442\u0430\u043A \u0447\u0442\u043E \u0442\u0430\u0441\u043A\u0430\u0442\u044C
    \u0435\u0433\u043E \u0441\u0442\u043E\u0438\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u043C, \u043A\u0442\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442
    \u0446\u0435\u043D\u0443 \u043B\u0438\u0448\u043D\u0435\u0439 \u043E\u0447\u0435\u0440\u0435\u0434\u0438."
