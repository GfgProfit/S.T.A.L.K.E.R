  m_Name: handguard_aks74u_caa_xrsu47su
  m_EditorClassIdentifier: 
  _itemName: "\u0426\u0435\u0432\u044C\u0435 \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    CAA \"XRSU47SU\" \u0434\u043B\u044F \u0410\u041A\u0421-74\u0423"
  _shortName: 
  _description: "CAA XRSU47SU \u2014 \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0446\u0435\u0432\u044C\u0451 \u0434\u043B\u044F \u0410\u041A\u0421-74\u0423,
    \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043D\u043D\u043E\u0435 \u043D\u0430
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439 \u0438 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u0435
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F \u043E\u0440\u0443\u0436\u0438\u044F.
    \u0412 \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0438\u0435 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0446\u0435\u043D\u044F\u0442 \u0442\u0435, \u043A\u0442\u043E \u0445\u043E\u0447\u0435\u0442
    \u0432\u044B\u0436\u0430\u0442\u044C \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C
    \u0438\u0437 \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0433\u043E \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0430:
    \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0444\u043E\u043D\u0430\u0440\u044C,
    \u043B\u0430\u0437\u0435\u0440\u043D\u044B\u0439 \u0446\u0435\u043B\u0435\u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
    \u0438\u043B\u0438 \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0443, \u043D\u0435
    \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044F \u043E\u0440\u0443\u0436\u0438\u0435
    \u0432 \u043C\u0443\u0437\u0435\u0439\u043D\u044B\u0439 \u044D\u043A\u0441\u043F\u043E\u043D\u0430\u0442.
    \u0414\u0435\u043B\u0430\u0435\u0442 \u0445\u0432\u0430\u0442 \u0443\u0434\u043E\u0431\u043D\u0435\u0435,
    \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u0435\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u043E\u0431\u0432\u0435\u0441\u0430 \u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442
    \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u0435\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0442\u0435\u0441\u043D\u044B\u0445 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u044F\u0445.
    \u0417\u0430 \u044D\u0442\u043E \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043F\u043B\u0430\u0442\u0438\u0442\u044C \u043B\u0438\u0448\u043D\u0438\u043C
    \u0432\u0435\u0441\u043E\u043C \u0438 \u0431\u043E\u043B\u0435\u0435 \u0437\u0430\u043C\u0435\u0442\u043D\u044B\u043C\u0438
    \u0433\u0430\u0431\u0430\u0440\u0438\u0442\u0430\u043C\u0438, \u043D\u043E \u0434\u043B\u044F
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0430, \u043F\u0440\u0438\u0432\u044B\u043A\u0448\u0435\u0433\u043E
    \u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C\u0441\u044F \u043A \u0445\u0443\u0434\u0448\u0435\u043C\u0443,
    \u0442\u0430\u043A\u0430\u044F \u0434\u043E\u0440\u0430\u0431\u043E\u0442\u043A\u0430
    \u0440\u0435\u0434\u043A\u043E \u0431\u044B\u0432\u0430\u0435\u0442 \u043B\u0438\u0448\u043D\u0435\u0439."
