  m_Name: handguard_aks74u_alfa_arms_goliaf
  m_EditorClassIdentifier: 
  _itemId: c95964fd243d9bc4bac212c72a79c6ad
  _itemName: "\u0426\u0435\u0432\u044C\u0435 Alfa Arms \"\u0413\u043E\u043B\u0438\u0430\u0444\"
    \u0434\u043B\u044F \u0410\u041A\u0421-74\u0423"
  _shortName: 
  _description: "Alfa Arms \u201C\u0413\u043E\u043B\u0438\u0430\u0444\u201D \u2014
    \u0443\u0441\u0438\u043B\u0435\u043D\u043D\u043E\u0435 \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0446\u0435\u0432\u044C\u0451 \u0434\u043B\u044F \u0410\u041A\u0421-74\u0423,
    \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043D\u043D\u043E\u0435 \u043D\u0430
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043E\u0431\u0432\u0435\u0441\u0430 \u0438 \u0431\u043E\u043B\u0435\u0435 \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u0439
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C \u043E\u0440\u0443\u0436\u0438\u044F.
    \u0412 \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0438\u0435 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044E\u0442\u0441\u044F \u043D\u0435\u0447\u0430\u0441\u0442\u043E:
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0443\u0436 \u0441\u043F\u0435\u0446\u0438\u0444\u0438\u0447\u043D\u0430\u044F
    \u0432\u0435\u0449\u044C \u0434\u043B\u044F \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0433\u043E
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0430, \u0437\u0430\u0442\u043E \u043F\u043E\u043B\u0435\u0437\u043D\u0430\u044F
    \u0434\u043B\u044F \u0442\u0435\u0445, \u043A\u0442\u043E \u043F\u0440\u0438\u0432\u044B\u043A
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0432 \u0442\u0435\u0441\u043D\u044B\u0445
    \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u044F\u0445 \u0438 \u043D\u0435
    \u0434\u043E\u0432\u0435\u0440\u044F\u0435\u0442 \u0448\u0442\u0430\u0442\u043D\u043E\u043C\u0443
    \u0436\u0435\u043B\u0435\u0437\u0443. \u041F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0443,
    \u0444\u043E\u043D\u0430\u0440\u044C \u0438\u043B\u0438 \u043B\u0430\u0437\u0435\u0440\u043D\u044B\u0439
    \u0446\u0435\u043B\u0435\u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C,
    \u0443\u043B\u0443\u0447\u0448\u0430\u0435\u0442 \u0445\u0432\u0430\u0442 \u0438
    \u0434\u0435\u043B\u0430\u0435\u0442 \u043E\u0440\u0443\u0436\u0438\u0435 \u0443\u0434\u043E\u0431\u043D\u0435\u0435
    \u043F\u0440\u0438 \u0431\u044B\u0441\u0442\u0440\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u0435.
    \u0417\u0430 \u043F\u0440\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0438 \u043C\u043E\u0434\u0443\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043F\u043B\u0430\u0442\u0438\u0442\u044C
    \u043B\u0438\u0448\u043D\u0438\u043C \u0432\u0435\u0441\u043E\u043C, \u043D\u043E
    \u0432 \u0445\u043E\u0440\u043E\u0448\u0438\u0445 \u0440\u0443\u043A\u0430\u0445
    \u0434\u0430\u0436\u0435 \u043A\u043E\u0440\u043E\u0442\u044B\u0448 \u043F\u043E\u0441\u043B\u0435
    \u0442\u0430\u043A\u043E\u0439 \u0434\u043E\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u0442\u044C
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u0435\u0435."
