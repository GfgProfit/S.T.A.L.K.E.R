  m_Name: stock_ak_zenit_pt_3_lock
  m_EditorClassIdentifier: 
  _itemId: 32c2006d7db250f479e592d15fad416f
  _itemName: "\u0417\u0430\u043C\u043E\u043A \u0417\u0435\u043D\u0438\u0442 \u0434\u043B\u044F
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043E\u0432 \"\u041F\u0422\" \u0434\u043B\u044F
    \u0410\u041A\u0421-74/\u0410\u041A\u0421-74\u0423"
  _shortName: 
  _description: "\u0417\u0430\u043C\u043E\u043A \u0417\u0435\u043D\u0438\u0442 \u0434\u043B\u044F
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043E\u0432 \u0441\u0435\u0440\u0438\u0438
    \u201C\u041F\u0422\u201D \u2014 \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u043D\u043E\u0439
    \u0443\u0437\u0435\u043B \u0434\u043B\u044F \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0441\u043A\u043B\u0430\u0434\u043D\u044B\u0445 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043E\u0432
    \u043D\u0430 \u0410\u041A\u0421-74 \u0438 \u0410\u041A\u0421-74\u0423. \u0412
    \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0438\u0435 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0446\u0435\u043D\u044F\u0442 \u043E\u0440\u0443\u0436\u0435\u0439\u043D\u0438\u043A\u0438
    \u0438 \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u0445\u043E\u0442\u044F\u0442 \u043C\u0438\u0440\u0438\u0442\u044C\u0441\u044F
    \u0441\u043E \u0448\u0442\u0430\u0442\u043D\u044B\u043C \u0436\u0435\u043B\u0435\u0437\u043E\u043C:
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u0438\u043A\u043B\u0430\u0434
    \u0440\u0435\u0448\u0430\u0435\u0442 \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0445\u043E\u0440\u043E\u0448\u0438\u0439 \u043F\u0440\u0438\u0446\u0435\u043B.
    \u041F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u044C
    \u0432\u043A\u043B\u0430\u0434\u043A\u0443, \u043F\u043E\u0434\u043E\u0433\u043D\u0430\u0442\u044C
    \u043E\u0440\u0443\u0436\u0438\u0435 \u043F\u043E\u0434 \u044D\u043A\u0438\u043F\u0438\u0440\u043E\u0432\u043A\u0443
    \u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u0443
    \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u0435\u0435. \u0421\u0430\u043C
    \u043F\u043E \u0441\u0435\u0431\u0435 \u043D\u0435 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442 \u0432 \u0448\u0435\u0434\u0435\u0432\u0440,
    \u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u043F\u0443\u0442\u044C
    \u043A \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0434\u043E\u0440\u0430\u0431\u043E\u0442\u043A\u0435
    \u043E\u0440\u0443\u0436\u0438\u044F \u043F\u043E\u0434 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0433\u043E
    \u0441\u0442\u0440\u0435\u043B\u043A\u0430."
