  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: magpul_afg
  m_EditorClassIdentifier: 
  _itemName: "\u0422\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0430 Magpul \"AFG\" (FDE)"
  _shortName: 
  _description: "Magpul AFG \u2014 \u0443\u0433\u043B\u043E\u0432\u0430\u044F \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0430 \u0432 \u043F\u0435\u0441\u043E\u0447\u043D\u043E\u043C
    \u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0438, \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u0430\u044F
    \u0434\u043B\u044F \u0431\u043E\u043B\u0435\u0435 \u0443\u0434\u043E\u0431\u043D\u043E\u0433\u043E
    \u0438 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0443\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F \u043E\u0440\u0443\u0436\u0438\u044F.
    \u0412 \u0417\u043E\u043D\u0435 \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0439
    \u043E\u0431\u0432\u0435\u0441 \u0447\u0430\u0449\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F
    \u0443 \u043D\u0430\u0451\u043C\u043D\u0438\u043A\u043E\u0432 \u0438 \u0445\u043E\u0440\u043E\u0448\u043E
    \u044D\u043A\u0438\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0446\u0435\u043D\u044F\u0442 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C
    \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0435, \u0447\u0435\u043C \u043E\u0433\u043D\u0435\u0432\u0443\u044E
    \u043C\u043E\u0449\u044C. \u041F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u0435\u0435
    \u0432\u0435\u0441\u0442\u0438 \u043E\u0440\u0443\u0436\u0438\u0435 \u043F\u0440\u0438
    \u0431\u044B\u0441\u0442\u0440\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u0435,
    \u0441\u043D\u0438\u0436\u0430\u0435\u0442 \u0443\u0441\u0442\u0430\u043B\u043E\u0441\u0442\u044C
    \u0440\u0443\u043A \u0438 \u0434\u0435\u043B\u0430\u0435\u0442 \u043F\u0435\u0440\u0435\u0445\u043E\u0434
    \u043C\u0435\u0436\u0434\u0443 \u0446\u0435\u043B\u044F\u043C\u0438 \u0431\u043E\u043B\u0435\u0435
    \u043F\u043B\u0430\u0432\u043D\u044B\u043C. \u041D\u0435 \u0434\u0430\u0451\u0442
    \u0442\u0430\u043A\u043E\u0439 \u0436\u0451\u0441\u0442\u043A\u043E\u0439 \u043E\u043F\u043E\u0440\u044B,
    \u043A\u0430\u043A \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u0430\u044F
    \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0430, \u0437\u0430\u0442\u043E \u043C\u0435\u043D\u044C\u0448\u0435
    \u0446\u0435\u043F\u043B\u044F\u0435\u0442\u0441\u044F \u0437\u0430 \u0441\u043D\u0430\u0440\u044F\u0436\u0435\u043D\u0438\u0435
    \u0438 \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043C\u0435\u0448\u0430\u0435\u0442
    \u043F\u0440\u0438 \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u043A\u0435."
