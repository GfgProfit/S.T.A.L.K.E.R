  m_Name: foregrip_all_zenit_rk_2
  m_EditorClassIdentifier: 
  _itemName: "\u0422\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0430 \u0417\u0435\u043D\u0438\u0442
    \"\u0420\u041A-2\""
  _shortName: 
  _description: "\u0417\u0435\u043D\u0438\u0442 \u0420\u041A-2 \u2014 \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u0430\u044F
    \u0442\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0440\u0443\u043A\u043E\u044F\u0442\u043A\u0430
    \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430,
    \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043D\u043D\u0430\u044F \u043D\u0430
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443 \u043D\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435
    \u043E\u0440\u0443\u0436\u0435\u0439\u043D\u043E\u0435 \u0446\u0435\u0432\u044C\u0451.
    \u0412 \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0438\u0435 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0446\u0435\u043D\u044F\u0442 \u0437\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0443
    \u0438 \u043F\u0440\u043E\u0447\u043D\u043E\u0441\u0442\u044C: \u043C\u0435\u043D\u044C\u0448\u0435
    \u043B\u0438\u0448\u043D\u0435\u0439 \u043A\u0440\u0430\u0441\u043E\u0442\u044B,
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F
    \u043D\u0430\u0434 \u043E\u0440\u0443\u0436\u0438\u0435\u043C. \u0423\u043B\u0443\u0447\u0448\u0430\u0435\u0442
    \u0443\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0430,
    \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u0431\u044B\u0441\u0442\u0440\u0435\u0435
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0442\u044C \u0441\u0442\u0432\u043E\u043B
    \u043D\u0430 \u0446\u0435\u043B\u044C \u0438 \u0434\u0435\u043B\u0430\u0435\u0442
    \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u0443 \u043E\u0447\u0435\u0440\u0435\u0434\u044F\u043C\u0438
    \u0431\u043E\u043B\u0435\u0435 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u043C\u043E\u0439.
    \u0417\u0430 \u0443\u0434\u043E\u0431\u0441\u0442\u0432\u043E \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043F\u043B\u0430\u0442\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0432\u0435\u0441\u043E\u043C \u0438 \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u043D\u044B\u043C\u0438
    \u0433\u0430\u0431\u0430\u0440\u0438\u0442\u0430\u043C\u0438. \u0425\u043E\u0440\u043E\u0448\u0438\u0439
    \u0432\u044B\u0431\u043E\u0440 \u0434\u043B\u044F \u0442\u0435\u0445, \u043A\u0442\u043E
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u0435\u0442 \u043D\u0430\u0434\u0451\u0436\u043D\u044B\u0439
    \u0445\u0432\u0430\u0442 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u043C \u0441\u043B\u043E\u0432\u0430\u043C."
