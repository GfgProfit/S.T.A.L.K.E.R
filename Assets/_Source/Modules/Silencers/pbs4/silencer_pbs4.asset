  _itemId: 4d17b9c7aed1a444aad32e518f903938
  _itemName: "\u0413\u043B\u0443\u0448\u0438\u0442\u0435\u043B\u044C \u041F\u0411\u0421-4
    5.45x39 \u0434\u043B\u044F \u0410\u041A\u0421-74\u0423"
  _shortName: 
  _description: "\u041F\u0411\u0421-4 \u2014 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u043B\u0443\u0448\u0438\u0442\u0435\u043B\u044C \u043F\u043E\u0434 \u043F\u0430\u0442\u0440\u043E\u043D
    5.45\xD739 \u043C\u043C, \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043D\u043D\u044B\u0439
    \u043D\u0430 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443 \u043D\u0430
    \u0410\u041A\u0421-74\u0423. \u0412 \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0430\u044F
    \u043D\u0430\u0441\u0430\u0434\u043A\u0430 \u0446\u0435\u043D\u0438\u0442\u0441\u044F
    \u0443 \u0442\u0435\u0445, \u043A\u0442\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u0435\u0442
    \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0435 \u0432\u044B\u043B\u0430\u0437\u043A\u0438
    \u0431\u0435\u0437 \u043B\u0438\u0448\u043D\u0435\u0433\u043E \u0448\u0443\u043C\u0430:
    \u043C\u0435\u043D\u044C\u0448\u0435 \u0432\u0441\u043F\u044B\u0448\u043A\u0430,
    \u0442\u0438\u0448\u0435 \u0432\u044B\u0441\u0442\u0440\u0435\u043B, \u043C\u0435\u043D\u044C\u0448\u0435
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0445 \u043F\u043E\u0441\u043B\u0435
    \u043F\u0435\u0440\u0432\u043E\u0439 \u043E\u0447\u0435\u0440\u0435\u0434\u0438.
    \u041B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043E \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0441 \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u043C\u0438 \u0431\u043E\u0435\u043F\u0440\u0438\u043F\u0430\u0441\u0430\u043C\u0438
    \u0438 \u043D\u0430 \u0431\u043B\u0438\u0436\u043D\u0435\u0439 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0438,
    \u0433\u0434\u0435 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u044B\u0439
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u0443\u0434\u043E\u0431\u043D\u044B\u043C \u0438 \u0431\u044B\u0441\u0442\u0440\u044B\u043C.
    \u0423\u0442\u044F\u0436\u0435\u043B\u044F\u0435\u0442 \u0441\u0442\u0432\u043E\u043B,
    \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0443\u0445\u043E\u0434\u0430 \u0438
    \u043D\u0435 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u043E\u0440\u0443\u0436\u0438\u0435
    \u0432 \u0431\u0435\u0441\u0448\u0443\u043C\u043D\u043E\u0435, \u043D\u043E \u0434\u0430\u0451\u0442
    \u0441\u0442\u0430\u043B\u043A\u0435\u0440\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0438\u0448\u043D\u0438\u0445 \u0441\u0435\u043A\u0443\u043D\u0434 \u0434\u043E
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0435\u0433\u043E \u0437\u0430\u043C\u0435\u0442\u044F\u0442."
