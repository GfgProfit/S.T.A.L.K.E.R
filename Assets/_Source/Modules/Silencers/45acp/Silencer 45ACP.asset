  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: Silencer 45ACP
  m_EditorClassIdentifier: 
  _itemId: 993cf0ead34cedb45938608322ed9e57
  _itemName: "\u0413\u043B\u0443\u0448\u0438\u0442\u0435\u043B\u044C .45ACP"
  _shortName: 
  _description: "\u0413\u043B\u0443\u0448\u0438\u0442\u0435\u043B\u044C \u043F\u043E\u0434
    .45 ACP \u2014 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u0434\u043B\u044F
    \u0441\u043D\u0438\u0436\u0435\u043D\u0438\u044F \u0437\u0432\u0443\u043A\u0430
    \u0432\u044B\u0441\u0442\u0440\u0435\u043B\u0430 \u0438 \u043F\u043E\u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0434\u0443\u043B\u044C\u043D\u043E\u0439 \u0432\u0441\u043F\u044B\u0448\u043A\u0438
    \u043D\u0430 \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u0430\u0445 \u043A\u0440\u0443\u043F\u043D\u043E\u0433\u043E
    \u043A\u0430\u043B\u0438\u0431\u0440\u0430. \u0412 \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0438\u0435
    \u0432\u0435\u0449\u0438 \u0446\u0435\u043D\u044F\u0442\u0441\u044F \u0443 \u0442\u0435\u0445,
    \u043A\u0442\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u0435\u0442
    \u043D\u0435 \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0442\u044C \u043B\u0438\u0448\u043D\u0438\u0439
    \u0448\u0443\u043C: \u043E\u0434\u0438\u043D \u0432\u044B\u0441\u0442\u0440\u0435\u043B
    \u0432 \u0442\u0435\u043C\u043D\u043E\u0442\u0435 \u0438\u043D\u043E\u0433\u0434\u0430
    \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u0435\u0435 \u0446\u0435\u043B\u043E\u0439
    \u043E\u0447\u0435\u0440\u0435\u0434\u0438 \u043D\u0430 \u0440\u0430\u0441\u0441\u0432\u0435\u0442\u0435.
    \u0425\u043E\u0440\u043E\u0448\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442
    \u0434\u043B\u044F \u0441\u043A\u0440\u044B\u0442\u043D\u043E\u0433\u043E \u0443\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u043E\u0434\u0438\u043D\u043E\u0447\u043D\u044B\u0445 \u0446\u0435\u043B\u0435\u0439
    \u043D\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0439 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0438,
    \u043D\u043E \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0435\u0442 \u0432\u0435\u0441,
    \u043C\u0435\u043D\u044F\u0435\u0442 \u0431\u0430\u043B\u0430\u043D\u0441 \u043E\u0440\u0443\u0436\u0438\u044F
    \u0438 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0443\u0445\u043E\u0434\u0430.
    \u041D\u0435 \u0434\u0435\u043B\u0430\u0435\u0442 \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u0443
    \u0431\u0435\u0441\u0448\u0443\u043C\u043D\u043E\u0439, \u0437\u0430\u0442\u043E
    \u0434\u0430\u0451\u0442 \u0448\u0430\u043D\u0441 \u043E\u0441\u0442\u0430\u0442\u044C\u0441\u044F
    \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u043C \u0442\u0430\u043C,
    \u0433\u0434\u0435 \u0433\u0440\u043E\u043C\u043A\u0438\u0439 \u0432\u044B\u0441\u0442\u0440\u0435\u043B
    \u0431\u044B\u0441\u0442\u0440\u043E \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442
    \u0433\u043E\u0441\u0442\u0435\u0439."
