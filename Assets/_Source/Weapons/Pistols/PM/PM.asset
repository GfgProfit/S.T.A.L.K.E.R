  _itemName: "\u041F\u0438\u0441\u0442\u043E\u043B\u0435\u0442 \u041C\u0430\u043A\u0430\u0440\u043E\u0432\u0430
    9\u044518"
  _shortName: "\u041F\u041C"
  _description: "\u041F\u041C \u2014 \u0441\u0442\u0430\u0440\u044B\u0439, \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0438 \u0434\u043E \u0431\u043E\u043B\u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0439
    \u0441\u0442\u0432\u043E\u043B, \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0448\u0438\u0439
    \u043D\u0435 \u043E\u0434\u043D\u0443 \u0441\u043C\u0435\u043D\u0443 \u0445\u043E\u0437\u044F\u0435\u0432.
    \u0412 \u0417\u043E\u043D\u0435 \u0435\u0433\u043E \u0446\u0435\u043D\u044F\u0442
    \u043D\u0435 \u0437\u0430 \u043C\u043E\u0449\u044C, \u0430 \u0437\u0430 \u043D\u0430\u0434\u0451\u0436\u043D\u043E\u0441\u0442\u044C:
    \u0441\u0442\u0440\u0435\u043B\u044F\u0435\u0442 \u043F\u043E\u0447\u0442\u0438
    \u0432 \u043B\u044E\u0431\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445,
    \u043B\u0435\u0433\u043A\u043E \u0447\u0438\u043D\u0438\u0442\u0441\u044F \u0438
    \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0440\u0435\u0434\u043A\u0438\u0445
    \u0431\u043E\u0435\u043F\u0440\u0438\u043F\u0430\u0441\u043E\u0432. \u041F\u0440\u043E\u0442\u0438\u0432
    \u043C\u0443\u0442\u0430\u043D\u0442\u043E\u0432 \u0438 \u0431\u0440\u043E\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0446\u0435\u043B\u0435\u0439 \u0441\u043B\u0430\u0431\u043E\u0432\u0430\u0442,
    \u0437\u0430\u0442\u043E \u0434\u043B\u044F \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E
    \u0448\u0430\u043D\u0441\u0430, \u0442\u0438\u0445\u043E\u0439 \u0432\u044B\u043B\u0430\u0437\u043A\u0438
    \u0438\u043B\u0438 \u0440\u0430\u0437\u0431\u043E\u0440\u043A\u0438 \u0441 \u0442\u0430\u043A\u0438\u043C
    \u0436\u0435 \u0431\u0435\u0434\u043E\u043B\u0430\u0433\u043E\u0439 \u2014 \u0432\u043F\u043E\u043B\u043D\u0435
    \u0441\u0433\u043E\u0434\u0438\u0442\u0441\u044F."
