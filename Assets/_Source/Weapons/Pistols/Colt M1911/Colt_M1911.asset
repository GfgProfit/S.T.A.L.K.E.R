  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: Colt_M1911
  m_EditorClassIdentifier: 
  _itemName: "\u041A\u043E\u043B\u044C\u0442 \u041C1911"
  _shortName: "\u041C1911"
  _description: "Colt M1911 \u2014 \u0441\u0442\u0430\u0440\u044B\u0439 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442 \u043F\u043E\u0434 \u043C\u043E\u0449\u043D\u044B\u0439
    \u043F\u0430\u0442\u0440\u043E\u043D .45 ACP. \u0412 \u0417\u043E\u043D\u0435
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F \u043D\u0435\u0447\u0430\u0441\u0442\u043E,
    \u043D\u043E \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0440\u0435\u0434\u0438 \u0442\u0435\u0445, \u043A\u0442\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u0435\u0442
    \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0449\u0435\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0440\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u0422\u044F\u0436\u0451\u043B\u044B\u0439, \u043D\u0430\u0434\u0451\u0436\u043D\u044B\u0439
    \u0438 \u0433\u0440\u0443\u0431\u044B\u0439, \u043E\u043D \u0445\u043E\u0440\u043E\u0448\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043D\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0439
    \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0438, \u043D\u043E \u0442\u0440\u0435\u0431\u0443\u0435\u0442
    \u0442\u0432\u0451\u0440\u0434\u043E\u0439 \u0440\u0443\u043A\u0438 \u0438 \u0447\u0430\u0441\u0442\u043E\u0433\u043E
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F \u0431\u043E\u0435\u0437\u0430\u043F\u0430\u0441\u0430.
    \u041D\u0435 \u0441\u0430\u043C\u044B\u0439 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u0439
    \u0432\u044B\u0431\u043E\u0440 \u0434\u043B\u044F \u0434\u043E\u043B\u0433\u043E\u0439
    \u0432\u044B\u043B\u0430\u0437\u043A\u0438, \u0437\u0430\u0442\u043E \u043E\u0434\u0438\u043D
    \u0442\u043E\u0447\u043D\u044B\u0439 \u0432\u044B\u0441\u0442\u0440\u0435\u043B
    \u0438\u0437 \u043D\u0435\u0433\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D
    \u0431\u044B\u0441\u0442\u0440\u043E \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C
    \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440."
