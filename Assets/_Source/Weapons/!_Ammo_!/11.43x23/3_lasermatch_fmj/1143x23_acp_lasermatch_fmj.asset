  m_Name: 1143x23_acp_lasermatch_fmj
  m_EditorClassIdentifier: 
  _itemId: ac15395dd5f07414c8d412a431ed6d36
  _itemName: .45 ACP Lasermatch FMJ
  _shortName: Laser
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D .45 ACP (11.43x23\u043C\u043C)
    Lasermatch FMJ \u0441 \u0442\u0440\u0430\u0441\u0441\u0438\u0440\u0443\u044E\u0449\u0435\u0439
    \u043F\u0443\u043B\u0435\u0439 \u043C\u0430\u0441\u0441\u043E\u0439 14,5 \u0433\u0440\u0430\u043C\u043C
    \u0441\u043E \u0441\u0432\u0438\u043D\u0446\u043E\u0432\u044B\u043C \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C,
    \u0432 \u043C\u0435\u0434\u043D\u043E\u0439 \u043E\u0431\u043E\u043B\u043E\u0447\u043A\u0435,
    \u0432 \u043B\u0430\u0442\u0443\u043D\u043D\u043E\u0439 \u0433\u0438\u043B\u044C\u0437\u0435.
    \u041F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u0434\u043B\u044F
    \u0446\u0435\u043B\u0435\u0443\u043A\u0430\u0437\u0430\u043D\u0438\u044F \u0438
    \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u043A\u0438
    \u043E\u0433\u043D\u044F \u0432 \u0431\u043E\u044E (\u0446\u0432\u0435\u0442
    \u0442\u0440\u0430\u0441\u0441\u0435\u0440\u0430: \u041A\u0440\u0430\u0441\u043D\u044B\u0439).
    \u041F\u0430\u0442\u0440\u043E\u043D \u0431\u044B\u043B \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D
    \u0434\u043B\u044F \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u043E\u0442\u0441\u043B\u0435\u0436\u0438\u0432\u0430\u043D\u0438\u044F
    \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043E\u0432-\u043F\u0443\u043B\u0435\u043C\u0435\u0442\u043E\u0432
    \u043A\u0430\u043B\u0438\u0431\u0440\u0430 .45 ACP \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0433\u043D\u044F. \u041F\u0443\u043B\u044F \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0443\u0431\u043E\u0439\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0430 \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0442\u044C
    \u0431\u0440\u043E\u043D\u044E \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
    \u0443\u0440\u043E\u0432\u043D\u044F \u0437\u0430\u0449\u0438\u0442\u044B."
