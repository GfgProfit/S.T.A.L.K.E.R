  m_Name: 1143x23_acp_rip
  m_EditorClassIdentifier: 
  _itemId: ca5665780c4bfe443a3bd3275fe7d498
  _itemName: .45 ACP RIP
  _shortName: RIP
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D .45 ACP (11.43x23\u043C\u043C)
    RIP (Radically Invasive Projectile) \u0441 \u0445\u0440\u0443\u043F\u043A\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439 \u043C\u0430\u0441\u0441\u043E\u0439 10,5 \u0433\u0440\u0430\u043C\u043C,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0439
    \u0434\u043B\u044F \u043D\u0430\u043D\u0435\u0441\u0435\u043D\u0438\u044F \u043A\u0440\u0438\u0442\u0438\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u0439 \u043C\u044F\u0433\u043A\u0438\u043C
    \u0442\u043A\u0430\u043D\u044F\u043C. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438 \u044D\u043A\u0441\u043F\u0430\u043D\u0441\u0438\u0432\u043D\u043E\u0439
    \u043F\u0443\u043B\u0438, \u043F\u0430\u0442\u0440\u043E\u043D \"R.I.P.\" \u0438\u043C\u0435\u0435\u0442
    8 \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0445 \u043D\u0430
    \u0441\u0442\u0430\u043D\u043A\u0435 \u0431\u0435\u0441\u0441\u0432\u0438\u043D\u0446\u043E\u0432\u044B\u0445
    \u043C\u0435\u0434\u043D\u044B\u0445 \u043B\u0435\u043F\u0435\u0441\u0442\u043A\u043E\u0432,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0445
    \u0434\u043B\u044F \u0431\u044B\u0441\u0442\u0440\u043E\u0433\u043E \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0432\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0432 \u0446\u0435\u043B\u044C
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u0445,
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044F \u0442\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u043D\u043E\u0435
    \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0449\u0435\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435."
