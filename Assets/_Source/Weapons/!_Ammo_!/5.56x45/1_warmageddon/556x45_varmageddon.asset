  m_Name: 556x45_varmageddon
  m_EditorClassIdentifier: 
  _itemId: 233fa388bf71c5f4c85d3e4626a15fcf
  _itemName: "5.56x45\u043C\u043C Warmageddon"
  _shortName: WAR
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D .223 Remington (5.56x45\u043C\u043C)
    Warmageddon \u0441 \u044D\u043A\u0441\u043F\u0430\u043D\u0441\u0438\u0432\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439 \u043C\u0430\u0441\u0441\u043E\u0439 3,6 \u0433\u0440\u0430\u043C\u043C
    \u0441 \u043F\u043E\u043B\u0438\u043C\u0435\u0440\u043D\u044B\u043C \u043D\u0430\u043A\u043E\u043D\u0435\u0447\u043D\u0438\u043A\u043E\u043C,
    \u0440\u0443\u0431\u0430\u0448\u043A\u043E\u0439 \u0438\u0437 \u043C\u0435\u0434\u043D\u043E\u0433\u043E
    \u0441\u043F\u043B\u0430\u0432\u0430, \u0441\u043E \u0441\u0432\u0438\u043D\u0446\u043E\u0432\u044B\u043C
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C, \u0432 \u043B\u0430\u0442\u0443\u043D\u043D\u043E\u0439
    \u0433\u0438\u043B\u044C\u0437\u0435. \u041F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u0434\u043B\u044F \u043E\u0445\u043E\u0442\u044B. \u041D\u0430\u043A\u043E\u043D\u0435\u0447\u043D\u0438\u043A
    \u043D\u0430 \u043F\u0443\u043B\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    \u043A\u0430\u043A \u043A\u043B\u0438\u043D \u043D\u0430 \u0441\u0432\u0438\u043D\u0446\u043E\u0432\u044B\u0439
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A \u043F\u0440\u0438 \u0443\u0434\u0430\u0440\u0435,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044F \u043F\u0443\u043B\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u0442\u044C\u0441\u044F
    \u0438 \u043D\u0430\u043D\u043E\u0441\u0438\u0442\u044C \u043D\u0435\u043F\u043E\u043F\u0440\u0430\u0432\u0438\u043C\u044B\u0439
    \u0443\u0440\u043E\u043D \u0446\u0435\u043B\u0438, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u043F\u043E\u043B\u043D\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u0433\u043E
    \u043F\u0430\u0442\u0440\u043E\u043D\u0430."
