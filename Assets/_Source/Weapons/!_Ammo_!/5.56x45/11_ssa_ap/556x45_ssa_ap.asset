  m_Name: 556x45_ssa_ap
  m_EditorClassIdentifier: 
  _itemId: 8251b394fbf0b8a49a5b5ee5a9b581e0
  _itemName: "5.56x45\u043C\u043C SSA AP"
  _shortName: SSA AP
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D 5.56x45\u043C\u043C NATO SSA
    AP \u0441 \u0434\u0432\u0443\u0445\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439, \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0438\u0437 \u043F\u043E\u0434\u0434\u043E\u043D\u0430 \u0438 \u043D\u0430\u043A\u043E\u043D\u0435\u0447\u043D\u0438\u043A\u0430-\u043F\u0435\u043D\u0435\u0442\u0440\u0430\u0442\u043E\u0440\u0430
    \u0438\u0437 \u043A\u0430\u0440\u0431\u0438\u0434\u0430 \u0432\u043E\u043B\u044C\u0444\u0440\u0430\u043C\u0430,
    \u0432 \u043B\u0430\u0442\u0443\u043D\u043D\u043E\u0439 \u0433\u0438\u043B\u044C\u0437\u0435.
    \u041F\u0443\u043B\u044F \u0431\u044B\u043B\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u0430,
    \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0442\u0438
    5,56x45\u043C\u043C \u041D\u0410\u0422\u041E M995 \u043F\u043E \u0431\u0440\u043E\u043D\u0435\u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u0438.
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0441\u0432\u043E\u0435\u0439
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438
    \u0438 \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0439
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438, \u043E\u043D\u0430
    \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442 \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u043D\u043E\u0439
    \u043F\u0440\u043E\u0431\u0438\u0432\u043D\u043E\u0439 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u043E\u043D\u0438 \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
    \u0438 \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F
    \u0437\u0430\u0449\u0438\u0442\u044B, \u0438 \u0434\u0430\u0436\u0435 \u043F\u0440\u043E\u0442\u0438\u0432
    \u0441\u0430\u043C\u044B\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0437\u0430\u0449\u0438\u0442\u044B
    5-6 \u043A\u043B\u0430\u0441\u0441\u0430. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u0438\u0437-\u0437\u0430 \u0441\u0432\u043E\u0435\u0439 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438,
    \u043F\u0443\u043B\u044F \u0438\u043C\u0435\u0435\u0442 \u0432\u044B\u0441\u043E\u043A\u0443\u044E
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C \u043E\u0442\u0441\u043A\u043E\u043A\u0430
    \u043E\u0442 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439."
