  _itemId: 7b71f4b3e2be8594a98a4edfe6c8076b
  _itemName: "7.62x51 \u0422\u041F\u0417 SP"
  _shortName: "\u0422\u041F\u0417"
  _description: "\u0422\u0443\u043B\u044C\u0441\u043A\u0438\u0439 \u043F\u043E\u043B\u0443\u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u044B\u0439
    \u043F\u0430\u0442\u0440\u043E\u043D 7.62x51 \u0438\u0437 \u0442\u0435\u0445,
    \u0447\u0442\u043E \u043F\u0430\u0445\u043D\u0443\u0442 \u0441\u043A\u043B\u0430\u0434\u043E\u043C,
    \u043C\u0430\u0441\u043B\u043E\u043C \u0438 \u0434\u0435\u0448\u0451\u0432\u043E\u0439
    \u043D\u0430\u0434\u0435\u0436\u0434\u043E\u0439. \u041F\u043E \u043F\u043B\u043E\u0442\u0438
    \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E
    \u0438 \u0441\u0442\u043E\u0438\u0442 \u043D\u0435 \u043A\u0430\u043A \u0440\u0435\u0434\u043A\u0438\u0439
    \u0438\u043C\u043F\u043E\u0440\u0442, \u043D\u043E \u0431\u0440\u043E\u043D\u0435\u0436\u0438\u043B\u0435\u0442
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0440\u0430\u0437\u043E\u0437\u043B\u0438\u0442,
    \u0447\u0435\u043C \u043F\u0440\u043E\u0431\u044C\u0451\u0442. \u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u044B\u0431\u043E\u0440 \u0434\u043B\u044F \u0445\u043E\u0434\u043A\u0438,
    \u0433\u0434\u0435 \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0431\u0435\u0434\u0430
    \u0445\u043E\u0434\u0438\u0442 \u043D\u0430 \u0447\u0435\u0442\u044B\u0440\u0451\u0445
    \u043B\u0430\u043F\u0430\u0445."
