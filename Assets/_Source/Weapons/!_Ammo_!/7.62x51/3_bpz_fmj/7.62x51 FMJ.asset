  m_Name: 7.62x51 FMJ
  m_EditorClassIdentifier: 
  _itemId: b6f5417a63f3bf4469f534f52b72cb63
  _itemName: "7.62x51 \u0411\u041F\u0417"
  _shortName: "\u0411\u041F\u0417"
  _description: "\u0411\u0430\u0440\u043D\u0430\u0443\u043B\u044C\u0441\u043A\u0438\u0439
    \u043E\u0431\u043E\u043B\u043E\u0447\u0435\u0447\u043D\u044B\u0439 \u043F\u0430\u0442\u0440\u043E\u043D
    7.62x51 \u0431\u0435\u0437 \u0440\u0435\u0434\u043A\u0438\u0445 \u0441\u043F\u043B\u0430\u0432\u043E\u0432
    \u0438 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0445 \u043E\u0431\u0435\u0449\u0430\u043D\u0438\u0439.
    \u041B\u0435\u0442\u0438\u0442 \u0440\u043E\u0432\u043D\u043E, \u043A\u043E\u0440\u043C\u0438\u0442
    \u0432\u0438\u043D\u0442\u043E\u0432\u043A\u0443 \u0431\u0435\u0437 \u043B\u0438\u0448\u043D\u0438\u0445
    \u043A\u0430\u043F\u0440\u0438\u0437\u043E\u0432 \u0438 \u0434\u0430\u0451\u0442
    \u043F\u0440\u0438\u0435\u043C\u043B\u0435\u043C\u044B\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043F\u043E \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0443
    \u0446\u0435\u043B\u0435\u0439. \u0421\u0442\u0430\u043B\u043A\u0435\u0440\u044B
    \u0431\u0435\u0440\u0443\u0442 \u0435\u0433\u043E \u043F\u0430\u0447\u043A\u0430\u043C\u0438,
    \u043A\u043E\u0433\u0434\u0430 \u0432\u043F\u0435\u0440\u0435\u0434\u0438 \u0434\u043E\u043B\u0433\u0430\u044F
    \u0434\u043E\u0440\u043E\u0433\u0430 \u0438 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437 \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
    \u0441\u0442\u0440\u0435\u043B\u044F\u0442\u044C."
