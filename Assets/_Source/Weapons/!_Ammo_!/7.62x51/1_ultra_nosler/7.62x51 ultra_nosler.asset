  m_Name: 7.62x51 ultra_nosler
  m_EditorClassIdentifier: 
  _itemId: a867dc2a04bb758499e84017132c8782
  _itemName: 7.62x51 Ultra Nosler
  _shortName: UN
  _description: "\u0420\u0435\u0434\u043A\u0438\u0439 \u043E\u0445\u043E\u0442\u043D\u0438\u0447\u0438\u0439
    \u043F\u0430\u0442\u0440\u043E\u043D 7.62x51 \u0441 \u043C\u044F\u0433\u043A\u043E\u0439
    \u044D\u043A\u0441\u043F\u0430\u043D\u0441\u0438\u0432\u043D\u043E\u0439 \u043F\u0443\u043B\u0435\u0439.
    \u041F\u043E \u043C\u0443\u0442\u0430\u043D\u0442\u0430\u043C \u0438 \u043D\u0435\u0437\u0430\u0449\u0438\u0449\u0451\u043D\u043D\u043E\u0439
    \u0446\u0435\u043B\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043E\u0442\u043B\u0438\u0447\u043D\u043E,
    \u0447\u0430\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u044F \u0434\u0435\u043B\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u043E\u043F\u0430\u0434\u0430\u043D\u0438\u0435\u043C,
    \u043D\u043E \u043F\u0440\u043E\u0442\u0438\u0432 \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\u0439
    \u0431\u0440\u043E\u043D\u0438 \u0431\u044B\u0441\u0442\u0440\u043E \u0442\u0435\u0440\u044F\u0435\u0442
    \u0441\u043C\u044B\u0441\u043B. \u0412 \u0417\u043E\u043D\u0435 \u0442\u0430\u043A\u0438\u0435
    \u0431\u0435\u0440\u0435\u0433\u0443\u0442 \u0434\u043B\u044F \u0437\u0432\u0435\u0440\u044C\u044F,
    \u0430 \u043D\u0435 \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u0435\u043B\u043E\u043A
    \u0441 \u043B\u044E\u0434\u044C\u043C\u0438."
