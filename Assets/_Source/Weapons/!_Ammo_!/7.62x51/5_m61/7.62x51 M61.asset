  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: 7.62x51 M61
  m_EditorClassIdentifier: 
  _itemId: c0e21653836a53b42a31e4dfcdd4477b
  _itemName: 7.62x51 M61
  _shortName: M61
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D 7.62x51\u043C\u043C \u041D\u0410\u0422\u041E
    M61 \u0441 \u0431\u0440\u043E\u043D\u0435\u0431\u043E\u0439\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439 \u043C\u0430\u0441\u0441\u043E\u0439 9,8 \u0433\u0440\u0430\u043C\u043C
    \u0441 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C \u0438\u0437
    \u0437\u0430\u043A\u0430\u043B\u0435\u043D\u043D\u043E\u0439 \u0441\u0442\u0430\u043B\u0438
    \u0438 \u043F\u043B\u0430\u043A\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0431\u0438\u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0431\u043E\u043B\u043E\u0447\u043A\u043E\u0439, \u0432 \u043B\u0430\u0442\u0443\u043D\u043D\u043E\u0439
    \u0433\u0438\u043B\u044C\u0437\u0435. \u041F\u0430\u0442\u0440\u043E\u043D \u0431\u044B\u043B
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D \u0432 1950-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \u043F\u0430\u0442\u0440\u043E\u043D\u0430 .30-06 Springfield AP M2 \u0434\u043B\u044F
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F \u0432\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0445
    \u0441\u0438\u043B \u0421\u0428\u0410 \u0431\u0440\u043E\u043D\u0435\u0431\u043E\u0439\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439 \u0434\u043B\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0440\u0443\u0436\u0438\u044F \u043A\u0430\u043B\u0438\u0431\u0440\u0430
    7.62x51\u043C\u043C \u041D\u0410\u0422\u041E, \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0439
    \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0442\u044C \u0441\u0430\u043C\u0443\u044E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u0431\u0440\u043E\u043D\u044E 5-6 \u043A\u043B\u0430\u0441\u0441\u0430 \u0437\u0430\u0449\u0438\u0442\u044B,
    \u0432\u0434\u043E\u0431\u0430\u0432\u043E\u043A \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044F
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0449\u0435\u0435
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u0438\u0437-\u0437\u0430 \u0441\u0432\u043E\u0435\u0439 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438,
    \u043F\u0443\u043B\u044F \u0438\u043C\u0435\u0435\u0442 \u0432\u044B\u0441\u043E\u043A\u0443\u044E
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C \u043E\u0442\u0441\u043A\u043E\u043A\u0430
    \u043E\u0442 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439."
