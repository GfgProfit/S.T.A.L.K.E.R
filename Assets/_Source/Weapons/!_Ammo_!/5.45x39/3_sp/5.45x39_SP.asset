  m_Script: {fileID: 11500000, guid: 737e751cd05516846acf43daad139c9e, type: 3}
  m_Name: 5.45x39_SP
  m_EditorClassIdentifier: 
  _itemId: b9e9547cbde9356459325ee1eed5686d
  _itemName: "5.45x39\u043C\u043C SP"
  _shortName: SP
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D 5.45\u044539\u043C\u043C \u0441
    \u043F\u0443\u043B\u0435\u0439 \u043C\u0430\u0441\u0441\u043E\u0439 3,6 \u0433\u0440\u0430\u043C\u043C
    \u0441 \u043C\u044F\u0433\u043A\u0438\u043C \u043D\u0430\u043A\u043E\u043D\u0435\u0447\u043D\u0438\u043A\u043E\u043C
    (SP - Soft-Point) \u0441\u043E \u0441\u0432\u0438\u043D\u0446\u043E\u0432\u044B\u043C
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C \u0441 \u0431\u0438\u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u043B\u0443\u043E\u0431\u043E\u043B\u043E\u0447\u043A\u043E\u0439,
    \u0432 \u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0439 \u0433\u0438\u043B\u044C\u0437\u0435.
    \u041F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u0434\u043B\u044F
    \u043E\u0445\u043E\u0442\u044B, \u043E\u0431\u043E\u0440\u043E\u043D\u044B \u0434\u043E\u043C\u0430
    \u0438 \u0442\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043E\u0447\u043D\u043E\u0439
    \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B. \u041F\u0443\u043B\u044F \u0438\u043C\u0435\u0435\u0442
    \u0445\u043E\u0440\u043E\u0448\u0435\u0435 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0435 \u043F\u0440\u0438
    \u0443\u0434\u0430\u0440\u0435 \u0438\u0437-\u0437\u0430 \u043E\u0431\u043D\u0430\u0436\u0435\u043D\u0438\u044F
    \u0441\u0432\u0438\u043D\u0446\u043E\u0432\u043E\u0433\u043E \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u0430
    \u043D\u0430 \u043D\u0430\u043A\u043E\u043D\u0435\u0447\u043D\u0438\u043A\u0435,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0434\u0430\u0435\u0442 \u0435\u0439 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0443\u0431\u043E\u0439\u043D\u043E\u0441\u0442\u044C \u0446\u0435\u043D\u043E\u0439
    \u043F\u043E\u0442\u0435\u0440\u0438 \u043F\u0440\u043E\u0431\u0438\u0432\u043D\u043E\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0434\u0430\u0436\u0435
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u043E\u043D\u0438 \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
    \u0443\u0440\u043E\u0432\u043D\u044F \u0437\u0430\u0449\u0438\u0442\u044B."
