  _itemId: 933ca204d246ca24fa5a1d948ae58c43
  _itemName: "5.45x39\u043C\u043C 7\u041D40"
  _shortName: "7\u041D40"
  _description: "\u041B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0439
    \u043D\u043E\u0432\u0435\u0439\u0448\u0438\u0439 \u043F\u0430\u0442\u0440\u043E\u043D
    \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0439 \u043A\u0443\u0447\u043D\u043E\u0441\u0442\u0438
    \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B 7\u041D40. \u0421\u0434\u0435\u043B\u0430\u043D
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B
    \"\u0420\u0430\u0442\u043D\u0438\u043A\" \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 7\u041D39 \u041F\u041F\u0411\u0421 \"\u0418\u0433\u043E\u043B\u044C\u043D\u0438\u043A\".
    \u041E\u0431\u043B\u0430\u0434\u0430\u0435\u0442 \u0445\u043E\u0440\u043E\u0448\u0435\u0439
    \u0431\u0440\u043E\u043D\u0435\u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u044C\u044E
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0421\u0418\u0411\u0417 \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
    \u0438 \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F
    \u0437\u0430\u0449\u0438\u0442\u044B, \u043E\u0434\u043D\u0430\u043A\u043E \u0438\u043C\u0435\u0435\u0442
    \u0432\u044B\u0441\u043E\u043A\u0443\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C
    \u043E\u0442\u0441\u043A\u043E\u043A\u0430 \u043E\u0442 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439."
