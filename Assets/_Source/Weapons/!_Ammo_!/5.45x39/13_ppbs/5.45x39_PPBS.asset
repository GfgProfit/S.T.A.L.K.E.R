  m_Name: 5.45x39_PPBS
  m_EditorClassIdentifier: 
  _itemId: 4f217a92ad281134b87a7b017d29c369
  _itemName: "5.45x39\u043C\u043C \u041F\u041F\u0411\u0421 \u0433\u0441 \"\u0418\u0433\u043E\u043B\u044C\u043D\u0438\u043A\""
  _shortName: "\u041F\u041F\u0411\u0421"
  _description: "\u041F\u0430\u0442\u0440\u043E\u043D 5.45x39\u043C\u043C \u041F\u041F\u0411\u0421
    \u0433\u0441 (\u0418\u043D\u0434\u0435\u043A\u0441 \u0413\u0420\u0410\u0423 -
    7\u041D39) \u0441 \u0431\u0440\u043E\u043D\u0435\u0431\u043E\u0439\u043D\u043E\u0439
    \u043F\u0443\u043B\u0435\u0439 \u043C\u0430\u0441\u0441\u043E\u0439 4 \u0433\u0440\u0430\u043C\u043C\u0430
    \u0441 \u0437\u0430\u043E\u0441\u0442\u0440\u0435\u043D\u043D\u044B\u043C \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A\u043E\u043C
    \u0438\u0437 \u043A\u0430\u0440\u0431\u0438\u0434\u0430 \u0432\u043E\u043B\u044C\u0444\u0440\u0430\u043C\u0430,
    \u0441 \u0434\u0432\u0443\u0445\u0441\u043B\u043E\u0439\u043D\u043E\u0439 \u043E\u0431\u043E\u043B\u043E\u0447\u043A\u043E\u0439,
    \u0432 \u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0439 \u0433\u0438\u043B\u044C\u0437\u0435.
    \u041F\u0430\u0442\u0440\u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D
    \u0426\u041D\u0418\u0418\u0422\u043E\u0447\u041C\u0430\u0448 \u0438 \u0422\u0435\u0445\u041A\u043E\u043C\u043F\u043B\u0435\u043A\u0442
    \u043F\u043E\u0434 \u0438\u043C\u0435\u043D\u0435\u043C 7\u041D39 \u041F\u041F\u0411\u0421
    \"\u0418\u0433\u043E\u043B\u044C\u043D\u0438\u043A\" (\u041F\u043E\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0439
    \u041F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u0438,
    \u0411\u0440\u043E\u043D\u0435\u0431\u043E\u0439\u043D\u044B\u0439 \u0421\u0435\u0440\u0434\u0435\u0447\u043D\u0438\u043A)
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u043F\u0430\u0442\u0440\u043E\u043D\u0430
    5.45x39\u043C\u043C \u0411\u0421 \u0433\u0441 \u0434\u043B\u044F \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u044F
    \u0435\u0433\u043E \u0431\u0440\u043E\u043D\u0435\u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u0438,
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044F \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u043F\u0440\u043E\u0442\u0438\u0432
    \u0441\u0430\u043C\u044B\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0437\u0430\u0449\u0438\u0442\u044B
    5-6 \u043A\u043B\u0430\u0441\u0441\u0430. \u041F\u0443\u043B\u044F \u0442\u0430\u043A\u0436\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0430 \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0442\u044C
    \u043B\u0435\u0433\u043A\u043E\u0431\u0440\u043E\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u0442\u0435\u0445\u043D\u0438\u043A\u0443 \u0438 \u0443\u043A\u0440\u044B\u0442\u0438\u044F,
    \u043E\u0434\u043D\u0430\u043A\u043E, \u0438\u0437-\u0437\u0430 \u0441\u0432\u043E\u0435\u0439
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438, \u0438\u043C\u0435\u0435\u0442
    \u0432\u044B\u0441\u043E\u043A\u0443\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C
    \u043E\u0442\u0441\u043A\u043E\u043A\u0430 \u043E\u0442 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439."
